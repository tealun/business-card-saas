# 运行环境：development=本地开发，production=生产，test=测试。
NODE_ENV=development

# 后端 HTTP 服务监听端口。
PORT=3030

# 后端 HTTP 服务监听地址；0.0.0.0 表示允许容器或局域网从外部访问该端口。
HOST=0.0.0.0

# 允许访问后端 API 的前端来源白名单，多个来源用英文逗号分隔。
# 例如 http://localhost:5173 是本地管理后台，https://admin.example.com 是线上管理后台。
# 浏览器跨域请求会校验 Origin；生产环境必须配置，否则服务启动会失败。
CORS_ORIGINS=http://localhost:5173,https://admin.example.com

# PostgreSQL 连接串；生产环境必填，格式必须以 postgres:// 或 postgresql:// 开头。
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/business_card_saas

# PostgreSQL 连接池最大连接数。
DATABASE_POOL_MAX=10

# 获取数据库连接的超时时间，单位毫秒。
DATABASE_CONNECT_TIMEOUT_MS=5000

# 空闲数据库连接被连接池回收前可保持的时间，单位毫秒。
DATABASE_IDLE_TIMEOUT_MS=30000

# 单条 SQL 语句的执行超时时间，单位毫秒。
DATABASE_STATEMENT_TIMEOUT_MS=15000

# 是否启用 PostgreSQL SSL 连接；本地通常用 disable，云数据库或生产环境可能需要 require。
DATABASE_SSL=disable

# 写入 PostgreSQL 连接信息中的应用名，便于数据库侧审计、监控和排查连接来源。
DATABASE_APPLICATION_NAME=business-card-backend

# 管理后台数据库迁移入口使用的 database/ 子项目目录。
# 生产部署通常为 database；本地若从 backend/ 目录启动后端，可改为 ../database。
DATABASE_DIR=database

# 必填密钥：每个环境都应使用不同的高强度随机值。
# 生产环境应从密钥管理系统或部署平台注入，不能提交真实密钥。
# 生成 32 字节 base64 密钥示例：
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# 普通用户会话 JWT 签名密钥；至少 32 字符，泄露后需要轮换并使旧 token 失效。
JWT_SECRET=change-me-in-production-use-a-long-random-string

# 管理后台会话 JWT 签名密钥；建议与普通用户 JWT_SECRET 完全不同。
ADMIN_JWT_SECRET=change-me-in-production-use-a-long-random-string

# 管理后台初始超级管理员（两项必须同时设置）。仅在该账号不存在时创建；
# 在后台修改密码后，这里的值即失效，可以从 .env 中删除。密码至少 8 位。
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=

# 公开名片访问、匿名访客等访问 token 的签名密钥；至少 32 字符。
VISIT_TOKEN_SECRET=change-me-in-production-use-a-long-random-string

# 名片敏感字段加密密钥，必须是 base64 编码后的 32 字节密钥。
CARD_FIELD_ENCRYPTION_KEY_BASE64=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# Demo 登录：默认关闭（不配置此项即为关闭）。
# 只有本地开发或演示环境需要时才取消注释并设为 1；生产环境禁止开启，否则会绕过真实认证流程且启动校验会失败。
# 识别为"开启"的取值：1 / true / yes / on；其余（含 0 / false / 空值 / 未设置）均为关闭。
# DEMO_AUTH_ENABLED=1

# Redis 连接地址；用于缓存、队列或需要共享状态的后端能力。
REDIS_URL=redis://localhost:6379

# 企业微信第三方 SaaS 服务商配置。
# 这里配置的是本 SaaS 应用在企业微信服务商后台创建的第三方应用套件信息，
# 不是某个租户企业自己的 CorpID、AgentID 或 Secret。
# 租户企业通过授权该套件接入；每个企业自己的授权信息会写入数据库 tenants 表，
# 例如 open_corpid、加密后的 permanent_code、agent_id 等。

# 企业微信 API 基础地址；通常不需要修改。
WECOM_API_BASE_URL=https://qyapi.weixin.qq.com

# 调用企业微信接口的 HTTP 超时时间，单位毫秒。
WECOM_HTTP_TIMEOUT_MS=5000

# 企业微信第三方应用套件 ID，来自企业微信服务商后台。
WECOM_PROVIDER_CORP_ID=wwprovider_xxx
WECOM_SUITE_ID=wwsuite_xxx

# 企业微信第三方应用套件 Secret，来自企业微信服务商后台，必须按密钥管理。
WECOM_SUITE_SECRET=wecom_suite_secret_xxx

# 指令回调的签名校验 Token 和消息解密 AES Key，用于接收 suite_ticket、授权变更等事件。
# 在企业微信后台将指令回调 URL 配置为：
# https://your-backend-domain.example/api/v1/wecom/callbacks/command
WECOM_CALLBACK_TOKEN=wecom_callback_token_xxx
WECOM_CALLBACK_AES_KEY=abcdefghijklmnopqrstuvwxyz0123456789ABCDEFG

# 数据回调的签名校验 Token 和消息解密 AES Key，用于接收通讯录、成员、客户等业务数据事件。
# 在企业微信后台将数据回调 URL 配置为：
# https://your-backend-domain.example/api/v1/wecom/callbacks/data
WECOM_DATA_CALLBACK_TOKEN=wecom_data_callback_token_xxx
WECOM_DATA_CALLBACK_AES_KEY=abcdefghijklmnopqrstuvwxyz0123456789ABCDEFG

# 服务商后台「登录授权」页的签名校验 Token 和消息解密 AES Key。
# 在登录授权页将指令回调 URL 配置为：
# https://your-backend-domain.example/api/v1/wecom/callbacks/login
WECOM_LOGIN_SUITE_ID=ww_login_authorization_suite_id
WECOM_LOGIN_SUITE_SECRET=wecom_login_authorization_suite_secret_xxx
WECOM_LOGIN_CALLBACK_TOKEN=wecom_login_callback_token_xxx
WECOM_LOGIN_CALLBACK_AES_KEY=abcdefghijklmnopqrstuvwxyz0123456789ABCDEFG

# 后端内部用于加密企业微信 state、permanent_code 等授权状态数据的密钥。
# 必须是 base64 编码后的 32 字节密钥。
WECOM_STATE_ENCRYPTION_KEY_BASE64=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# 创建企业微信安装授权链接时使用的内部保护 token。
# 调用创建链接接口时需要通过请求头传入，不能暴露给租户用户或前端页面。
WECOM_AUTH_LAUNCH_TOKEN=replace_with_internal_random_launch_token

# 企业微信授权完成后回调到本后端的地址，需要使用真实后端域名并与企业微信后台配置保持一致。
WECOM_INSTALL_REDIRECT_URI=https://your-backend-domain.example/api/v1/wecom/authorization-complete
WECOM_SENSITIVE_REDIRECT_URI=https://your-backend-domain.example/api/v1/wecom/member-sensitive/callback
WECOM_ADMIN_LOGIN_REDIRECT_URI=https://your-admin-domain.example/

# 企业微信第三方应用安装授权页基础地址；通常不需要修改。
WECOM_INSTALL_BASE_URL=https://open.work.weixin.qq.com/3rdapp/install

# 可选：企业微信回调处理异常时发送内部运维告警的 Webhook 地址；不用可留空。
WECOM_CALLBACK_ALERT_WEBHOOK_URL=

# 可选：调用内部运维告警 Webhook 时附带的认证 token；不用可留空。
WECOM_CALLBACK_ALERT_WEBHOOK_TOKEN=

# 普通微信小程序登录配置；用于微信 App 内 wx.login -> /api/v1/auth/wx-login。
# 这些是小程序后台的 AppID / AppSecret，只放在后端环境变量，不能放进小程序包。
WECHAT_MINIPROGRAM_APPID=wx_miniprogram_appid_xxx
WECHAT_MINIPROGRAM_SECRET=wx_miniprogram_secret_xxx
WECHAT_HTTP_TIMEOUT_MS=5000

# Prometheus 指标抓取令牌。默认不配置即关闭 GET /api/v1/metrics（返回 404）。
# 配置后，抓取方需带 Authorization: Bearer <该值> 才能访问，避免运行时指标公网暴露。
# METRICS_TOKEN=replace_with_random_scrape_token

# Storage configuration. All uploaded assets should go through this layer.
# local stores files on the backend host.
# aliyun_oss is Alibaba Cloud Object Storage Service.
# s3 is for AWS S3 and S3-compatible services such as MinIO or Cloudflare R2.
STORAGE_DRIVER=local
# Empty defaults to ./storage/uploads under the backend runtime directory.
STORAGE_LOCAL_ROOT=
# Empty returns portable /api/v1/storage paths. Clients resolve them against
# their configured API origin. Set an absolute URL only for a separate CDN/OSS.
STORAGE_PUBLIC_BASE_URL=
STORAGE_MAX_UPLOAD_BYTES=5242880

# Required only when STORAGE_DRIVER=aliyun_oss.
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_REGION=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=

# Required only when STORAGE_DRIVER=s3.
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
