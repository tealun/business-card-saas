NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,https://admin.example.com
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/business_card_saas
DATABASE_POOL_MAX=10
DATABASE_CONNECT_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_SSL=disable
DATABASE_APPLICATION_NAME=business-card-backend

# Required secrets — generate strong random values for every environment.
# In production these are loaded from a secrets manager, never committed.
# Generate 32-byte base64 keys with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=change-me-in-production-use-a-long-random-string
ADMIN_JWT_SECRET=change-me-in-production-use-a-long-random-string
VISIT_TOKEN_SECRET=change-me-in-production-use-a-long-random-string
CARD_FIELD_ENCRYPTION_KEY_BASE64=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# Demo auth is disabled by default. Set to 1 only for local development.
# Never enable in production.
DEMO_AUTH_ENABLED=0

REDIS_URL=redis://localhost:6379

WECOM_API_BASE_URL=https://qyapi.weixin.qq.com
WECOM_HTTP_TIMEOUT_MS=5000
WECOM_SUITE_ID=wwsuite_xxx
WECOM_SUITE_SECRET=wecom_suite_secret_xxx
WECOM_CALLBACK_TOKEN=wecom_callback_token_xxx
WECOM_CALLBACK_AES_KEY=abcdefghijklmnopqrstuvwxyz0123456789ABCDEFG
WECOM_DATA_CALLBACK_TOKEN=wecom_data_callback_token_xxx
WECOM_DATA_CALLBACK_AES_KEY=abcdefghijklmnopqrstuvwxyz0123456789ABCDEFG
WECOM_STATE_ENCRYPTION_KEY_BASE64=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
WECOM_AUTH_LAUNCH_TOKEN=replace_with_internal_random_launch_token
WECOM_INSTALL_REDIRECT_URI=https://api.example.com/api/v1/wecom/authorization-complete
WECOM_INSTALL_BASE_URL=https://open.work.weixin.qq.com/3rdapp/install
WECOM_CALLBACK_ALERT_WEBHOOK_URL=
WECOM_CALLBACK_ALERT_WEBHOOK_TOKEN=
