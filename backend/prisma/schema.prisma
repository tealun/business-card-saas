generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id            BigInt   @id @default(autoincrement())
  wxUnionid     String?  @map("wx_unionid") @db.VarChar(128)
  primaryOpenid String?  @map("primary_wx_openid") @db.VarChar(128)
  status        String   @default("active") @db.VarChar(32)
  createdAt     DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @map("updated_at") @db.Timestamptz(6)

  bindings    AccountIdentityBinding[]
  preferences AccountPreference?

  @@unique([wxUnionid], map: "uk_accounts_unionid")
  @@map("accounts")
}

model Tenant {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(255)
  openCorpid  String   @unique(map: "uk_tenants_open_corpid") @map("open_corpid") @db.VarChar(128)
  authStatus  String   @default("active") @map("auth_status") @db.VarChar(32)
  createdAt   DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @map("updated_at") @db.Timestamptz(6)

  members MemberIdentity[]
  cards   Card[]
  admins  TenantAdmin[]
  adminClaimTokens AdminClaimToken[]

  @@map("tenants")
}

model MemberIdentity {
  id         BigInt   @id @default(autoincrement())
  tenantId   BigInt   @map("tenant_id")
  openUserid String?  @map("open_userid") @db.VarChar(128)
  name       String   @db.VarChar(128)
  status     String   @default("active") @db.VarChar(32)
  createdAt  DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant                   @relation(fields: [tenantId], references: [id])
  cards    Card[]
  bindings AccountIdentityBinding[]
  tenantAdmins TenantAdmin[]

  @@unique([tenantId, id], map: "uk_mi_tenant_id")
  @@unique([tenantId, openUserid], map: "uk_member_open_userid")
  @@index([tenantId], map: "idx_member_tenant")
  @@map("member_identities")
}

model AccountIdentityBinding {
  id               BigInt   @id @default(autoincrement())
  accountId        BigInt   @map("account_id")
  tenantId         BigInt   @map("tenant_id")
  memberIdentityId BigInt   @map("member_identity_id")
  bindSource       String   @map("bind_source") @db.VarChar(32)
  createdAt        DateTime @map("created_at") @db.Timestamptz(6)

  account Account        @relation(fields: [accountId], references: [id])
  member  MemberIdentity @relation(fields: [memberIdentityId], references: [id])

  @@unique([accountId, memberIdentityId], map: "uk_account_identity")
  @@index([accountId], map: "idx_binding_account")
  @@index([tenantId], map: "idx_binding_tenant")
  @@map("account_identity_bindings")
}

model AccountPreference {
  accountId               BigInt   @id @map("account_id")
  defaultMemberIdentityId BigInt?  @map("default_member_identity_id")
  lastMemberIdentityId    BigInt?  @map("last_member_identity_id")
  updatedAt               DateTime @map("updated_at") @db.Timestamptz(6)

  account Account @relation(fields: [accountId], references: [id])

  @@map("account_preferences")
}

model Card {
  id               BigInt   @id @default(autoincrement())
  tenantId         BigInt   @map("tenant_id")
  memberIdentityId BigInt   @map("member_identity_id")
  publicId         String   @unique(map: "uk_cards_public_id") @map("public_id") @db.VarChar(32)
  cardType         String   @default("primary") @map("card_type") @db.VarChar(32)
  slug             String   @db.VarChar(64)
  displayName      String?  @map("display_name") @db.VarChar(128)
  title            String?  @db.VarChar(128)
  emailEncrypted   String?  @map("email_encrypted")
  phoneEncrypted   String?  @map("phone_encrypted")
  privacyJson      Json?    @map("privacy_json")
  status           String   @default("active") @db.VarChar(32)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt        DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  member MemberIdentity @relation(fields: [tenantId, memberIdentityId], references: [tenantId, id])
  visits CardVisit[]
  actions CardAction[]
  shares CardShare[]

  @@unique([tenantId, id], map: "uk_cards_tenant_id")
  @@index([tenantId], map: "idx_cards_tenant")
  @@map("cards")
}

model PublicCardDirectory {
  publicId      String   @id @map("public_id") @db.VarChar(32)
  tenantId      BigInt   @map("tenant_id")
  cardId        BigInt   @map("card_id")
  status        String   @default("active") @db.VarChar(32)
  cardUpdatedAt DateTime? @map("card_updated_at") @db.Timestamptz(6)
  createdAt     DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId, cardId], map: "idx_public_card_directory_tenant")
  @@map("public_card_directory")
}

model VisitorAccount {
  id        BigInt   @id @default(autoincrement())
  appid     String   @db.VarChar(64)
  wxOpenid  String?  @map("wx_openid") @db.VarChar(128)
  wxUnionid String?  @map("wx_unionid") @db.VarChar(128)
  nickname  String?  @db.VarChar(128)
  avatar    String?
  createdAt DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @map("updated_at") @db.Timestamptz(6)

  @@unique([appid, wxOpenid], map: "uk_visitor_app_openid")
  @@index([wxUnionid], map: "idx_visitor_unionid")
  @@map("visitor_accounts")
}

model CardVisit {
  id               BigInt   @id @default(autoincrement())
  tenantId         BigInt   @map("tenant_id")
  cardId           BigInt   @map("card_id")
  memberIdentityId BigInt   @map("member_identity_id")
  visitorAccountId BigInt?  @map("visitor_account_id")
  shareId          String?  @map("share_id") @db.VarChar(64)
  visitId          String?  @unique(map: "uk_visit_id") @map("visit_id") @db.VarChar(64)
  anonId           String?  @map("anon_id") @db.VarChar(64)
  trustLevel       String   @default("anonymous_client") @map("trust_level") @db.VarChar(32)
  channel          String?  @db.VarChar(64)
  userAgent        String?  @map("user_agent")
  ipHash           String?  @map("ip_hash") @db.VarChar(128)
  createdAt        DateTime @map("created_at") @db.Timestamptz(6)

  card Card @relation(fields: [tenantId, cardId], references: [tenantId, id])

  @@index([tenantId, cardId], map: "idx_visit_card")
  @@index([tenantId, shareId], map: "idx_visit_share")
  @@index([createdAt], map: "idx_visit_created")
  @@map("card_visits")
}

model CardAction {
  id               BigInt   @id @default(autoincrement())
  tenantId         BigInt   @map("tenant_id")
  cardId           BigInt   @map("card_id")
  memberIdentityId BigInt   @map("member_identity_id")
  visitorAccountId BigInt?  @map("visitor_account_id")
  actionType       String   @map("action_type") @db.VarChar(64)
  shareId          String?  @map("share_id") @db.VarChar(64)
  visitId          String?  @map("visit_id") @db.VarChar(64)
  trustLevel       String   @default("anonymous_client") @map("trust_level") @db.VarChar(32)
  createdAt        DateTime @map("created_at") @db.Timestamptz(6)

  card Card @relation(fields: [tenantId, cardId], references: [tenantId, id])

  @@unique([visitId, actionType], map: "uk_action_idem")
  @@index([tenantId, cardId], map: "idx_action_card")
  @@index([tenantId, actionType], map: "idx_action_type")
  @@map("card_actions")
}

model CardShare {
  id                     BigInt   @id @default(autoincrement())
  tenantId               BigInt   @map("tenant_id")
  cardId                 BigInt   @map("card_id")
  memberIdentityId       BigInt   @map("member_identity_id")
  publicShareId          String   @unique(map: "uk_public_share_id") @map("public_share_id") @db.VarChar(64)
  parentShareId          String?  @map("parent_share_id") @db.VarChar(64)
  issuerType             String   @default("member") @map("issuer_type") @db.VarChar(16)
  issuerVisitorAccountId BigInt?  @map("issuer_visitor_account_id")
  depth                  Int      @default(0) @db.SmallInt
  channel                String?  @db.VarChar(64)
  scene                  String?  @db.VarChar(64)
  createdAt              DateTime @map("created_at") @db.Timestamptz(6)

  card Card @relation(fields: [tenantId, cardId], references: [tenantId, id])

  @@index([tenantId, cardId], map: "idx_share_card")
  @@index([tenantId, memberIdentityId], map: "idx_share_member")
  @@map("card_shares")
}

model TenantAdmin {
  id               BigInt   @id @default(autoincrement())
  tenantId         BigInt   @map("tenant_id")
  memberIdentityId BigInt?  @map("member_identity_id")
  openUserid       String?  @map("open_userid") @db.VarChar(128)
  role             String   @db.VarChar(32)
  status           String   @default("active") @db.VarChar(32)
  createdAt        DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])
  member MemberIdentity? @relation(fields: [tenantId, memberIdentityId], references: [tenantId, id])

  @@unique([tenantId, openUserid], map: "uk_tenant_admin_user")
  @@index([tenantId], map: "idx_tenant_admin_tenant")
  @@map("tenant_admins")
}

model AdminClaimToken {
  id        BigInt    @id @default(autoincrement())
  tenantId  BigInt    @map("tenant_id")
  tokenHash String    @unique(map: "uk_admin_claim_token") @map("token_hash") @db.VarChar(128)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "idx_admin_claim_tenant")
  @@map("admin_claim_tokens")
}
