{
  "name": "business-card-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --runInBand",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:verify": "node scripts/db-verify.cjs",
    "rls:validate": "node scripts/validate-rls.cjs",
    "db:migrate": "node-pg-migrate up",
    "db:migrate:create": "node-pg-migrate create"
  },
  "dependencies": {
    "@fastify/helmet": "13.0.2",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-fastify": "11.1.27",
    "@nestjs/throttler": "6.5.0",
    "fastify": "5.8.5",
    "nestjs-pino": "4.6.1",
    "node-pg-migrate": "8.0.4",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.0.5"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.7",
    "@nestjs/testing": "11.1.27",
    "@types/jest": "30.0.0",
    "@types/node": "24.0.15",
    "@types/pg": "8.20.0",
    "@typescript-eslint/eslint-plugin": "8.37.0",
    "@typescript-eslint/parser": "8.37.0",
    "eslint": "9.31.0",
    "jest": "30.0.4",
    "ts-jest": "29.4.0",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  }
}
