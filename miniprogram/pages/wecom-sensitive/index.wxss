.sensitive-page { min-height: 100vh; padding: 48rpx 32rpx; box-sizing: border-box; background: #f4f6f8; }
.sensitive-card { padding: 48rpx 36rpx; border-radius: 24rpx; background: #fff; text-align: center; color: #5f6672; }
.sensitive-title { margin-bottom: 20rpx; color: #20242b; font-size: 34rpx; font-weight: 600; }
.sensitive-desc { margin-bottom: 32rpx; font-size: 28rpx; line-height: 1.6; }
.sensitive-button { background: #5a70c8; color: #fff; border-radius: 16rpx; }
