.admin-page {
  min-height: 100vh;
  background: #f3f5f8;
  color: #111827;
  box-sizing: border-box;
}

.admin-state {
  min-height: 100vh;
  padding: 120rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-sizing: border-box;
}

.admin-state__mark {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 28rpx;
}

.admin-state__icon {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 28rpx;
  border-radius: 32rpx;
  background: #eef2ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-state__icon--danger {
  background: #fff1f1;
}

.admin-state__title {
  font-size: 40rpx;
  font-weight: 800;
  color: #111827;
}

.admin-state__desc {
  margin-top: 16rpx;
  font-size: 27rpx;
  line-height: 1.6;
  color: #6b7280;
}

.admin-primary {
  width: 100%;
  height: 92rpx;
  margin-top: 36rpx;
  border-radius: 18rpx;
  background: #5272d6;
  color: #fff;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 92rpx;
}

.admin-select-head {
  padding: 40rpx 40rpx 16rpx;
}

.admin-select-title {
  font-size: 44rpx;
  line-height: 1.2;
  font-weight: 800;
}

.admin-select-desc {
  margin-top: 12rpx;
  font-size: 27rpx;
  color: #6b7280;
}

.tenant-option {
  margin: 18rpx 32rpx 0;
  padding: 28rpx 30rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, .08);
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.tenant-option__logo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #5272d6;
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
}

.tenant-option__main {
  min-width: 0;
  flex: 1;
}

.tenant-option__name {
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
}

.tenant-option__role {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.admin-hero {
  padding: 18rpx 32rpx 24rpx;
  background:
    radial-gradient(circle at 16rpx 16rpx, rgba(255,255,255,.18) 0 2rpx, transparent 3rpx) 0 0 / 42rpx 42rpx,
    linear-gradient(145deg, #3152a9 0%, #5577da 100%);
  color: #fff;
}

.admin-hero__top {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.admin-icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-icon-btn .icon-home,
.admin-icon-btn .icon-reload {
  background-color: #fff;
}

.admin-tenant {
  margin-top: 34rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.admin-tenant__logo {
  width: 92rpx;
  height: 92rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 800;
  flex: none;
}

.admin-tenant__main {
  min-width: 0;
  flex: 1;
}

.admin-tenant__name {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.15;
}

.admin-tenant__meta {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,.88);
}

.admin-tabs {
  display: flex;
  gap: 18rpx;
  padding: 22rpx 32rpx 8rpx;
}

.admin-tab {
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #fff;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 64rpx;
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, .04);
}

.admin-tab--active {
  color: #fff;
  background: #5272d6;
}

.admin-inline-error {
  margin: 14rpx 32rpx 0;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fef3f2;
  color: #b42318;
  font-size: 25rpx;
  line-height: 1.5;
}

.admin-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin: 18rpx 32rpx 0;
}

.admin-stat {
  padding: 26rpx 18rpx;
  border-radius: 20rpx;
  background: #fff;
  text-align: center;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, .06);
}

.admin-stat__num {
  font-size: 40rpx;
  font-weight: 800;
  color: #111827;
}

.admin-stat__label {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #6b7280;
}

.admin-section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 28rpx 32rpx 14rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.admin-section-head text {
  font-size: 23rpx;
  color: #6b7280;
  font-weight: 500;
}

.admin-action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin: 0 32rpx;
}

.admin-action {
  min-height: 136rpx;
  padding: 18rpx 12rpx;
  border-radius: 20rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, .06);
  box-sizing: border-box;
}

.admin-action text {
  font-size: 23rpx;
  color: #374151;
}

.join-request {
  margin: 0 32rpx 14rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, .06);
}

.join-request__main {
  flex: 1;
  min-width: 0;
}

.join-request__name {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.join-request__meta {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.member-toolbar {
  display: flex;
  gap: 14rpx;
  margin: 18rpx 32rpx 0;
}

.member-search {
  flex: 1;
  height: 78rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, .06);
}

.member-search input {
  flex: 1;
  min-width: 0;
  height: 78rpx;
  font-size: 26rpx;
}

.member-status-tabs {
  display: flex;
  gap: 12rpx;
  padding: 18rpx 32rpx 0;
}

.member-status {
  height: 54rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #fff;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 54rpx;
}

.member-status--active {
  color: #fff;
  background: #5272d6;
}

.member-actions {
  display: flex;
  gap: 12rpx;
  padding: 18rpx 32rpx 0;
}

.member-card {
  margin: 18rpx 32rpx 0;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, .06);
}

.member-card__top {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.member-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 18rpx;
  background: #5272d6;
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
}

.member-main {
  min-width: 0;
  flex: 1;
}

.member-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
}

.member-meta {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.member-contact {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #374151;
}

.member-card__actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.settings-list {
  margin: 16rpx 32rpx 0;
}

.settings-item {
  margin-bottom: 14rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, .06);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.settings-item__icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 18rpx;
  background: #eef2ff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
}

.settings-item__main {
  min-width: 0;
  flex: 1;
}

.settings-item__title {
  font-size: 28rpx;
  font-weight: 800;
  color: #111827;
}

.settings-item__desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  color: #6b7280;
}

.admin-sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, .38);
  z-index: 180;
}

.admin-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 88vh;
  border-radius: 30rpx 30rpx 0 0;
  background: #f8fafc;
  z-index: 190;
  box-shadow: 0 -20rpx 42rpx rgba(15, 23, 42, .16);
}

.admin-sheet__head {
  padding: 26rpx 28rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.admin-sheet__title {
  font-size: 32rpx;
  font-weight: 800;
  color: #111827;
}

.admin-sheet__close {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #eef2ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.admin-sheet__body {
  max-height: calc(88vh - 100rpx);
  padding: 0 28rpx 28rpx;
  box-sizing: border-box;
}

.form-row {
  min-height: 92rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e8edf5;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.form-row text {
  width: 140rpx;
  flex: none;
  font-size: 26rpx;
  color: #374151;
}

.form-row input {
  flex: 1;
  min-width: 0;
  height: 92rpx;
  font-size: 26rpx;
  color: #111827;
}

.upload-field {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fff;
  border: 1rpx solid #e1e7f1;
  box-sizing: border-box;
}

.upload-field__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.upload-field__head text {
  color: #374151;
  font-size: 26rpx;
  font-weight: 700;
}

.upload-actions {
  display: flex;
  gap: 10rpx;
  flex: none;
}

.upload-preview {
  width: 100%;
  height: 260rpx;
  margin-top: 16rpx;
  border-radius: 16rpx;
  background: #eef2f7;
  display: block;
}

.upload-preview--logo {
  width: 128rpx;
  height: 128rpx;
}

.uploaded-path {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #f3f5f8;
  color: #516075;
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-all;
}

.upload-empty {
  margin-top: 14rpx;
  padding: 18rpx 16rpx;
  border-radius: 14rpx;
  background: #f7f9fc;
  color: #7a8799;
  font-size: 23rpx;
  text-align: center;
}

.media-editor-list {
  margin-top: 16rpx;
  display: grid;
  gap: 14rpx;
}

.media-editor {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
  padding: 14rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  box-sizing: border-box;
}

.media-editor__thumb {
  width: 128rpx;
  height: 112rpx;
  border-radius: 14rpx;
  background: #eef2f7;
  flex: none;
}

.media-editor__main {
  flex: 1;
  min-width: 0;
  display: grid;
  gap: 10rpx;
}

.media-editor__input {
  width: 100%;
  min-width: 0;
  height: 62rpx;
  padding: 0 14rpx;
  border-radius: 14rpx;
  background: #fff;
  border: 1rpx solid #e1e7f1;
  box-sizing: border-box;
  font-size: 24rpx;
}

.media-editor__delete {
  justify-self: start;
}

.switch-row,
.seg-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.switch-row text {
  font-size: 26rpx;
  color: #374151;
}

.seg {
  flex: 1;
  height: 64rpx;
  border-radius: 16rpx;
  background: #e9edf5;
  color: #6b7280;
  text-align: center;
  line-height: 64rpx;
  font-size: 25rpx;
}

.seg--active {
  background: #5272d6;
  color: #fff;
}

.sheet-primary,
.sheet-secondary,
.sheet-tertiary {
  width: 100%;
  height: 92rpx;
  margin-top: 24rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 92rpx;
}

.sheet-primary {
  background: #5272d6;
  color: #fff;
}

.sheet-secondary {
  background: #fff;
  color: #516075;
  border: 1rpx solid #d7ddea;
}

.sheet-tertiary {
  background: transparent;
  color: #6b7280;
  border: 1rpx dashed #cfd7e6;
}

.field-title {
  margin-top: 22rpx;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #111827;
}

.template-list {
  display: grid;
  gap: 14rpx;
}

.template-chip {
  padding: 20rpx;
  border-radius: 18rpx;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 10rpx 22rpx rgba(15, 23, 42, .05);
}

.template-chip--active {
  outline: 2rpx solid #5272d6;
}

.template-chip__swatch {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  flex: none;
}

.template-chip__name {
  font-size: 28rpx;
  font-weight: 700;
}

.template-chip__meta {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.variant-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.variant {
  padding: 18rpx;
  border-radius: 16rpx;
  background: #fff;
  text-align: center;
  font-size: 24rpx;
  color: #516075;
}

.variant--active {
  background: #eef2ff;
  color: #2747a6;
}

.swatch-row {
  display: flex;
  gap: 14rpx;
}

.swatch {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
}

.swatch--active {
  border-color: #111827;
}

.module-row {
  margin-top: 12rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #e8edf5;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.module-row__main {
  flex: 1;
  min-width: 0;
}

.module-row__title {
  font-size: 27rpx;
  font-weight: 700;
}

.module-row__layout {
  margin-top: 6rpx;
  display: inline-flex;
  padding: 0 14rpx;
  border-radius: 12rpx;
  background: #eef2ff;
  color: #2747a6;
  font-size: 22rpx;
  line-height: 40rpx;
}

.content-tabs,
.block-type-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.content-tab,
.block-type {
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: #fff;
  color: #516075;
  font-size: 24rpx;
  line-height: 58rpx;
  border: 1rpx solid #d7ddea;
  box-sizing: border-box;
}

.content-tab--active,
.block-type--active {
  color: #fff;
  background: #5272d6;
  border-color: #5272d6;
}

.intro-compose {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.intro-compose input,
.intro-input,
.intro-textarea {
  flex: 1;
  width: 100%;
  min-width: 0;
  border: 1rpx solid #d9e1ee;
  border-radius: 16rpx;
  background: #fff;
  padding: 18rpx 20rpx;
  font-size: 25rpx;
  box-sizing: border-box;
}

.intro-textarea {
  min-height: 140rpx;
}

.intro-textarea--tall {
  min-height: 210rpx;
}

.mini-btn {
  height: 66rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  line-height: 66rpx;
}

.mini-btn--ghost {
  background: #fff;
  color: #516075;
  border: 1rpx solid #d7ddea;
}

.mini-btn--primary {
  background: #5272d6;
  color: #fff;
}

.mini-btn--danger {
  background: #fff1f1;
  color: #b42318;
  border: 1rpx solid #f4c7c3;
}

.content-card,
.intro-block {
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #fff;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: flex-start;
  box-shadow: 0 10rpx 22rpx rgba(15, 23, 42, .05);
}

.content-card__cover {
  width: 120rpx;
  height: 92rpx;
  border-radius: 14rpx;
  background: #eef2f7;
  flex: none;
}

.content-card__main,
.intro-block__main {
  flex: 1;
  min-width: 0;
}

.content-card__title,
.intro-block__type {
  font-size: 27rpx;
  font-weight: 800;
  color: #111827;
}

.content-card__desc,
.intro-block__text {
  margin-top: 4rpx;
  font-size: 25rpx;
  color: #516075;
  line-height: 1.45;
  word-break: break-all;
}

.content-card__meta {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.content-card__actions {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.content-card__actions--full {
  margin-top: 4rpx;
}

.video-feature {
  margin-bottom: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #e8f8ef;
  color: #149255;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
  font-weight: 700;
}

.video-feature--off {
  background: #fff4e5;
  color: #b54708;
}

.join-code-box {
  margin: 18rpx 32rpx 0;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #fff;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, .06);
}

.join-code-box__title {
  font-size: 26rpx;
  font-weight: 700;
}

.join-code-box__meta {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.empty-list {
  margin: 24rpx 32rpx 0;
  padding: 28rpx;
  border-radius: 18rpx;
  background: #fff;
  color: #6b7280;
  text-align: center;
  font-size: 25rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  height: 36rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  font-size: 21rpx;
  white-space: nowrap;
}

.badge--success {
  color: #149255;
  background: #e8f8ef;
}

.badge--warning {
  color: #b54708;
  background: #fff4e5;
}

.invite-token {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #fff;
}

.invite-token__label {
  font-size: 22rpx;
  color: #6b7280;
}

.invite-token__value {
  margin: 10rpx 0 16rpx;
  font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  font-size: 24rpx;
  word-break: break-all;
  color: #111827;
}
