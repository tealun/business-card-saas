.claim-page{min-height:100vh;background:#f4f6f8;padding:48rpx 28rpx;box-sizing:border-box}.claim-card{background:#fff;border-radius:24rpx;padding:40rpx 32rpx;box-shadow:0 12rpx 40rpx rgba(25,35,65,.08)}.claim-title{font-size:40rpx;font-weight:700;color:#1f2937}.claim-desc{font-size:26rpx;line-height:1.7;color:#6b7280;margin:20rpx 0 36rpx}.claim-input{height:92rpx;border:2rpx solid #e5e7eb;border-radius:16rpx;padding:0 24rpx;margin-bottom:28rpx;background:#fafafa}.claim-button{border-radius:16rpx}.claim-success,.claim-error{margin-top:28rpx;padding:20rpx;border-radius:14rpx;font-size:26rpx}.claim-success{background:#ecfdf5;color:#047857}.claim-error{background:#fef2f2;color:#b91c1c}
