.legal-page { min-height: 100vh; padding: 28rpx 24rpx calc(72rpx + env(safe-area-inset-bottom)); box-sizing: border-box; background: radial-gradient(circle at 92% 2%, rgba(90, 112, 200, 0.17), transparent 25%), #f4f6f8; }
.legal-hero { padding: 38rpx 20rpx 48rpx; }
.legal-hero__label { margin-bottom: 18rpx; font-size: 20rpx; letter-spacing: 5rpx; font-weight: 600; color: #7585c2; }
.legal-hero__title { font-size: 54rpx; line-height: 1.2; font-weight: 700; letter-spacing: 1rpx; color: #171b2d; }
.legal-hero__meta { margin-top: 20rpx; font-size: 23rpx; line-height: 1.6; color: #7b8391; }
.legal-paper { padding: 42rpx 36rpx 50rpx; border: 1rpx solid rgba(255, 255, 255, 0.9); border-radius: 32rpx; background: rgba(255, 255, 255, 0.96); box-shadow: 0 18rpx 60rpx rgba(35, 43, 76, 0.08); }
.legal-intro { margin-bottom: 44rpx; padding: 26rpx 28rpx; border-left: 6rpx solid #5a70c8; border-radius: 0 18rpx 18rpx 0; font-size: 27rpx; line-height: 1.85; color: #4f5868; background: #f2f4fb; }
.legal-section { margin-bottom: 42rpx; }
.legal-section:last-child { margin-bottom: 0; }
.legal-section__title { margin-bottom: 18rpx; font-size: 31rpx; line-height: 1.5; font-weight: 650; color: #202535; }
.legal-section__paragraph { margin-bottom: 16rpx; font-size: 27rpx; line-height: 1.95; text-align: justify; color: #596171; }
.legal-section__paragraph:last-child { margin-bottom: 0; }
.legal-footer { padding: 48rpx 0 8rpx; text-align: center; font-size: 21rpx; letter-spacing: 2rpx; color: #a1a8b4; }
