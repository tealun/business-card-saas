<view class="page {{!loggedIn ? 'page--with-login' : ''}} tabbar-safe" style="{{themeStyle}}">
  <view class="page__content">
    <view class="status-bar status-bar--warning" wx:if="{{authState === 'guest'}}">
      当前为未登录体验，演示数据仅用于预览流程，登录后会同步你的真实名片。
    </view>
    <view class="status-bar status-bar--danger" wx:elif="{{authState === 'failed'}}">
      登录失败，当前展示演示数据。请点击底部登录按钮重试。
    </view>

    <view class="identity-strip" wx:if="{{currentIdentity}}">
      <view class="identity-strip__main">
        <text class="badge {{currentIdentity.badgeClass}}">{{currentIdentity.typeLabel}}</text>
        <view class="identity-strip__text">
          <view class="identity-strip__name">{{currentIdentity.display_name || "我的名片"}}</view>
          <view class="identity-strip__sub">{{currentIdentity.subtitle}}</view>
        </view>
      </view>
      <view class="btn btn--sm btn--soft identity-strip__btn" bindtap="openIdentitySheet">切换</view>
    </view>

    <view
      class="wecom-sync-card"
      wx:if="{{currentIdentity && currentIdentity.identity_type === 'wecom_member' && wecomSensitive.should_authorize}}"
    >
      <view class="wecom-sync-card__text">
        <view class="wecom-sync-card__title">同步当前企业微信资料</view>
        <view class="wecom-sync-card__desc">授权后会更新当前企业名片的姓名、职位、头像和联系方式。</view>
      </view>
      <view class="btn btn--sm btn--primary wecom-sync-card__btn" bindtap="startWecomSensitiveAuthorization">
        {{wecomSensitiveSyncing ? "打开中" : "授权同步"}}
      </view>
    </view>

    <block wx:if="{{loading}}">
      <view class="card skeleton-card">
        <view class="skeleton skeleton-line skeleton-line--short"></view>
        <view class="skeleton skeleton-line skeleton-line--name"></view>
        <view class="skeleton skeleton-line"></view>
        <view class="skeleton skeleton-line skeleton-line--short"></view>
      </view>
    </block>

    <block wx:else>
      <view class="biz-card home-card {{cardTemplateClass}}" style="{{cardBackgroundStyle}}" bindtap="goEdit">
        <view class="biz-card__head" wx:if="{{showCardHead}}">
          <view class="biz-card__logo" wx:if="{{cardLogoUrl || card.company_short_name}}">
            <image wx:if="{{cardLogoUrl}}" class="biz-card__logo-img" src="{{cardLogoUrl}}" mode="aspectFit" />
            <block wx:else>
              <image class="biz-card__logo-img biz-card__logo-img--color" src="/assets/logo/color-nobg.png" mode="aspectFit" />
              <image class="biz-card__logo-img biz-card__logo-img--white" src="/assets/logo/white-nobg.png" mode="aspectFit" />
            </block>
          </view>
          <text class="biz-card__company" wx:if="{{card.company_short_name}}">{{card.company_short_name}}</text>
        </view>
        <view class="biz-card__body">
          <view class="biz-card__info">
            <view class="biz-card__company-full" wx:if="{{card.company}}">{{card.company}}</view>
            <view class="biz-card__name">{{card.display_name || "我的名片"}}</view>
            <view class="biz-card__role" wx:if="{{card.title}}">{{card.title}}</view>
            <view class="biz-card__contact">
              <view wx:if="{{card.fields.mobile || card.fields.phone}}">{{card.fields.mobile || card.fields.phone}}</view>
              <view wx:if="{{card.fields.email}}">{{card.fields.email}}</view>
            </view>
          </view>
          <view class="biz-card__avatar" wx:if="{{card.show_avatar}}">
            <image wx:if="{{card.avatar_url}}" src="{{card.avatar_url}}" mode="aspectFill" class="avatar-img" />
            <view wx:else class="avatar-placeholder"></view>
          </view>
        </view>
        <view class="biz-card__status" wx:if="{{card.status !== 'active'}}">
          <text wx:if="{{card.status === 'disabled'}}" class="badge badge--warning">已停用</text>
          <text wx:else class="badge badge--muted">未启用</text>
        </view>
        <view class="biz-card__type-corner biz-card__type-corner--interactive" catchtap="openIdentityInfo">
          <view class="icon {{currentIdentity && currentIdentity.identity_type === 'personal' ? 'icon-person' : 'icon-building'}}"></view>
        </view>
      </view>

      <view class="card quick-bar">
        <view class="quick-bar__item" bindtap="goEdit">
          <view class="icon icon-edit"></view>
          <text>编辑资料</text>
        </view>
        <view class="quick-bar__sep"></view>
        <view class="quick-bar__item" bindtap="goStyle">
          <view class="icon icon-style"></view>
          <text>名片样式</text>
        </view>
        <view class="quick-bar__sep"></view>
        <view class="quick-bar__item" bindtap="openIdentitySheet">
          <view class="icon icon-switch"></view>
          <text>切换名片</text>
        </view>
      </view>

      <view class="btn btn--primary btn--block send-btn" bindtap="openSheet">
        <view class="icon icon-send icon--sm"></view>
        <text>发名片</text>
      </view>

      <view class="card tool-grid">
        <view class="tool-grid__item" bindtap="choosePaperCardImage">
          <view class="icon icon-paper"></view>
          <text>纸质名片</text>
        </view>
        <view class="tool-grid__item" bindtap="handleWechatTool">
          <view class="icon icon-wechat"></view>
          <text>{{currentIdentity && currentIdentity.identity_type === "wecom_member" ? "同步企微资料" : "设置微信号"}}</text>
        </view>
        <view class="tool-grid__item" bindtap="showPoster">
          <view class="icon icon-poster"></view>
          <text>名片海报</text>
        </view>
        <view class="tool-grid__item" bindtap="showCardCode">
          <view class="icon icon-qrcode"></view>
          <text>名片码</text>
        </view>
        <view class="tool-grid__item" bindtap="openSheet">
          <view class="icon icon-grid"></view>
          <text>全部</text>
        </view>
      </view>

      <view class="card" wx:if="{{requests.length}}">
        <view class="row-between">
          <text class="card__title">交换请求</text>
          <text class="card__more">有 {{requests.length}} 人请求交换</text>
        </view>
        <view class="request-item" wx:for="{{requests}}" wx:key="id">
          <view class="request-item__avatar"><view class="avatar-placeholder"></view></view>
          <view class="request-item__info">
            <view class="f14 medium">{{item.name}}</view>
            <view class="f12 t-secondary">{{item.title}}</view>
          </view>
          <view class="btn btn--sm btn--muted" data-id="{{item.id}}" catchtap="ignoreRequest">忽略</view>
          <view class="btn btn--sm btn--primary" data-id="{{item.id}}" catchtap="acceptRequest">同意</view>
        </view>
      </view>

      <view class="card">
        <text class="card__title">我的名片数据</text>
        <view class="stat-row">
          <view class="stat-row__item">
            <view class="stat-row__num t-brand">{{stats.visitors}}</view>
            <view class="stat-row__label">访客</view>
          </view>
          <view class="stat-row__item">
            <view class="stat-row__num">{{stats.viewed}}</view>
            <view class="stat-row__label">我看过</view>
          </view>
          <view class="stat-row__item">
            <view class="stat-row__num">{{stats.friends}}</view>
            <view class="stat-row__label">好友名片</view>
          </view>
        </view>
        <view class="divider"></view>
        <view class="f13 t-secondary" wx:if="{{!recentVisitors.length}}">暂无访客记录，发出名片后这里会展示访问动态。</view>
        <view class="visitor-item" wx:for="{{recentVisitors}}" wx:key="id">
          <view class="visitor-item__avatar visitor-item__avatar--{{item.state}}">
            <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" mode="aspectFill" class="avatar-img" />
            <view wx:else class="avatar-placeholder"></view>
          </view>
          <view class="visitor-item__info">
            <view class="f14 medium">{{item.name}}</view>
            <view class="f12 t-secondary">{{item.title}}</view>
          </view>
          <view class="visitor-item__right">
            <text class="badge badge--success" wx:if="{{item.state === 'exchanged'}}">已交换</text>
            <text class="badge badge--warning" wx:elif="{{item.state === 'pending'}}">待通过</text>
            <text class="f12 t-secondary" wx:elif="{{item.meta}}">{{item.meta}}</text>
            <text class="visitor-item__time">{{item.time}}</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <login-bar
    wx:if="{{!loggedIn}}"
    text="开始使用"
    bind:success="onLoginSuccess"
    bind:fail="onLoginFail"
  />

  <view class="sheet-mask {{sheetVisible ? 'sheet-mask--show' : ''}}" catchtap="closeSheet"></view>
  <view class="sheet {{sheetVisible ? 'sheet--show' : ''}}">
    <view class="sheet__grab"></view>
    <view class="row-between sheet__head">
      <text class="card__title">发名片</text>
      <view class="icon icon-close icon--sm" catchtap="closeSheet"></view>
    </view>
    <view class="sheet__thumb share-current-card">
      <view class="share-current-card__icon">
        <view class="icon icon-wecom icon--sm"></view>
      </view>
      <view class="share-current-card__info">
        <view class="sheet__thumb-title">{{card.display_name || "我的名片"}}</view>
        <view class="sheet__thumb-sub">
          <text wx:if="{{card.title}}">{{card.title}}</text>
          <text wx:if="{{card.title && card.company}}"> · </text>
          <text wx:if="{{card.company}}">{{card.company}}</text>
        </view>
      </view>
      <view class="share-current-card__tag">当前名片</view>
    </view>
    <view class="sheet__grid sheet__grid--share">
      <view class="sheet__cell sheet__cell--primary" bindtap="createShare">
        <view class="icon icon-forward"></view>
        <view class="sheet__cell-title">转发给好友/群</view>
        <view class="sheet__cell-desc">微信内直接送达</view>
        <text>转发给好友/群</text>
      </view>
      <view class="sheet__cell sheet__cell--primary" bindtap="showPoster">
        <view class="icon icon-poster"></view>
        <view class="sheet__cell-title">名片海报</view>
        <view class="sheet__cell-desc">含公开页小程序码</view>
        <text>名片海报</text>
      </view>
      <view class="sheet__cell sheet__cell--secondary" bindtap="showCardCode">
        <view class="icon icon-qrcode"></view>
        <text>名片码</text>
      </view>
      <view class="sheet__cell sheet__cell--secondary" bindtap="choosePaperCardImage">
        <view class="icon icon-paper"></view>
        <text>纸质名片</text>
      </view>
    </view>
    <view class="sheet__tip">分享内容仅包含公开编号与渠道编号，敏感字段由隐私开关控制。</view>
  </view>

  <view class="sheet-mask {{previewSheetVisible ? 'sheet-mask--show' : ''}}" catchtap="closePreviewSheet"></view>
  <view class="sheet preview-sheet {{previewFullscreen ? 'preview-sheet--fullscreen' : ''}} {{previewSheetVisible ? 'sheet--show' : ''}}">
    <view class="sheet__grab"></view>
    <view class="row-between sheet__head">
      <text class="card__title">{{previewTitle}}</text>
      <view class="icon icon-close icon--sm" catchtap="closePreviewSheet"></view>
    </view>
    <view class="poster-preview poster-preview--stack">
      <view class="poster-card poster-card--large" wx:if="{{previewMode === 'poster'}}">
        <view class="poster-card__top">{{card.company || "名片"}}</view>
        <view class="poster-card__name">{{card.display_name || "我的名片"}}</view>
        <view class="poster-card__qr"></view>
      </view>
      <view class="qr-preview" wx:else>
        <image wx:if="{{previewQrUrl}}" src="{{previewQrUrl}}" mode="aspectFit" />
        <view wx:else class="qr-preview__placeholder"></view>
      </view>
      <view class="poster-preview__copy">
        <view class="poster-preview__title">{{previewTitle}}</view>
        <view class="f12 t-secondary" wx:if="{{previewMode === 'wechat'}}">长按识别加微信</view>
        <view class="f12 t-secondary" wx:else>扫描直达当前名片访客展示页</view>
        <view class="share-note__path" wx:if="{{previewPath}}">{{previewPath}}</view>
      </view>
    </view>
  </view>

  <view class="sheet-mask {{identitySheetVisible ? 'sheet-mask--show' : ''}}" catchtap="closeIdentitySheet"></view>
  <view class="sheet {{identitySheetVisible ? 'sheet--show' : ''}}">
    <view class="sheet__grab"></view>
    <view class="row-between sheet__head">
      <text class="card__title">切换名片</text>
      <view class="icon icon-close icon--sm" catchtap="closeIdentitySheet"></view>
    </view>
    <view class="identity-list">
      <view
        class="identity-option {{item.selected ? 'identity-option--active' : ''}}"
        wx:for="{{identities}}"
        wx:key="member_identity_id"
        data-id="{{item.member_identity_id}}"
        bindtap="chooseIdentity"
      >
        <view class="identity-option__avatar"><view class="avatar-placeholder"></view></view>
        <view class="identity-option__body">
          <view class="identity-option__top">
            <text class="identity-option__name">{{item.optionName || item.display_name || "我的名片"}}</text>
            <text class="badge {{item.badgeClass}}">{{item.typeLabel}}</text>
            <text class="badge badge--warning" wx:if="{{item.isDemo}}">样例</text>
          </view>
          <view class="identity-option__sub">{{item.subtitle}}</view>
        </view>
        <view class="icon icon-check icon--sm identity-option__check" wx:if="{{item.selected}}"></view>
      </view>
    </view>
    <view class="btn btn--soft btn--sm btn--block identity-refresh" catchtap="refreshIdentities">
      {{refreshingIdentities ? "正在刷新身份..." : "刷新企业身份"}}
    </view>
    <view class="sheet__tip">{{switchingIdentity ? "正在切换当前发送身份..." : "看不到自己的企业？企业授权接入后，点击“刷新企业身份”重新拉取。"}}</view>
  </view>

  <canvas id="shareCardCanvas" type="2d" class="share-card-canvas"></canvas>
</view>
