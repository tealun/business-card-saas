<view class="page page--with-footer edit-page">
  <view class="card">
    <view class="row-between">
      <text class="card__title">基础信息</text>
      <text class="badge badge--brand">员工可维护</text>
    </view>
    <view class="edit-avatar-row">
      <text class="field-row__label">头像</text>
      <view class="edit-avatar">{{form.display_name ? form.display_name[0] : "名"}}</view>
    </view>
    <view class="field-row">
      <text class="field-row__label">姓名</text>
      <input class="field-row__value" value="{{form.display_name}}" data-key="display_name" bindinput="onInput" placeholder="请输入姓名" />
    </view>
    <view class="field-row">
      <text class="field-row__label">职位</text>
      <input class="field-row__value" value="{{form.title}}" data-key="title" bindinput="onInput" placeholder="请输入职位" />
    </view>
    <view class="field-row" bindtap="lockedTip">
      <view class="field-row__label"><view class="icon icon-lock icon--sm"></view><text>部门</text></view>
      <view class="field-row__value field-row__value--locked">{{form.department || "企业统一维护"}}</view>
    </view>
    <view class="field-row field-row--textarea">
      <text class="field-row__label">简介</text>
      <input class="field-row__value" value="{{form.bio}}" data-key="bio" bindinput="onInput" placeholder="一句话介绍自己" />
    </view>
  </view>

  <view class="card">
    <text class="card__title">联系方式</text>
    <view class="field-row">
      <text class="field-row__label">手机</text>
      <input class="field-row__value" value="{{form.mobile}}" data-key="mobile" type="number" bindinput="onInput" placeholder="未填写" />
    </view>
    <view class="field-row">
      <text class="field-row__label">座机</text>
      <input class="field-row__value" value="{{form.phone}}" data-key="phone" bindinput="onInput" placeholder="未填写" />
    </view>
    <view class="field-row">
      <text class="field-row__label">邮箱</text>
      <input class="field-row__value" value="{{form.email}}" data-key="email" bindinput="onInput" placeholder="未填写" />
    </view>
    <view class="field-row">
      <text class="field-row__label">微信号</text>
      <input class="field-row__value" value="{{form.wechat_id}}" data-key="wechat_id" bindinput="onInput" placeholder="未填写" />
    </view>
    <view class="field-row" bindtap="lockedTip">
      <view class="field-row__label"><view class="icon icon-lock icon--sm"></view><text>公司地址</text></view>
      <view class="field-row__value field-row__value--locked">{{form.address || "企业统一维护"}}</view>
    </view>
    <view class="field-row" bindtap="lockedTip">
      <view class="field-row__label"><view class="icon icon-lock icon--sm"></view><text>官网</text></view>
      <view class="field-row__value field-row__value--locked">{{form.website || "企业统一维护"}}</view>
    </view>
  </view>

  <view class="card">
    <text class="card__title">展示标签</text>
    <view class="edit-tags">
      <text class="chip" wx:for="{{tags}}" wx:key="*this">{{item}}</text>
      <view class="edit-tags__add"><view class="icon icon-plus icon--sm"></view><text>添加标签</text></view>
    </view>
  </view>

  <view class="card">
    <text class="card__title">隐私设置</text>
    <view class="field-row">
      <text class="field-row__label">手机号对访客公开</text>
      <switch checked="{{privacy.show_mobile}}" color="#2b6cff" data-key="show_mobile" bindchange="onPrivacy" />
    </view>
    <view class="field-row">
      <text class="field-row__label">邮箱对访客公开</text>
      <switch checked="{{privacy.show_email}}" color="#2b6cff" data-key="show_email" bindchange="onPrivacy" />
    </view>
    <view class="field-row">
      <text class="field-row__label">微信号对访客公开</text>
      <switch checked="{{privacy.show_wechat}}" color="#2b6cff" data-key="show_wechat" bindchange="onPrivacy" />
    </view>
  </view>

  <view class="edit-note">灰色带锁字段由企业统一维护；手机号等敏感字段默认不公开，保存后名片将立即更新。</view>
</view>

<view class="fixed-footer">
  <view class="btn btn--primary btn--block {{submitting ? 'btn--disabled' : ''}}" bindtap="saveCard">
    {{submitting ? '保存中…' : '保存并更新名片'}}
  </view>
</view>
