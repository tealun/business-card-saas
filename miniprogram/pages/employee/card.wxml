<view class="page page--with-footer card-page">
  <view class="status-bar status-bar--warning" wx:if="{{error}}">
    当前为演示名片，连接企业微信后会自动同步真实资料。
  </view>
  <view class="card skeleton-card" wx:if="{{loading}}">
    <view class="skeleton skeleton-line skeleton-line--short"></view>
    <view class="skeleton skeleton-line skeleton-line--name"></view>
    <view class="skeleton skeleton-line"></view>
    <view class="skeleton skeleton-line skeleton-line--short"></view>
  </view>
  <view class="biz-card">
    <view class="biz-card__head">
      <view class="biz-card__logo"></view>
      <text class="biz-card__company">{{card.company || "智云科技"}}</text>
    </view>
    <view class="biz-card__body">
      <view class="biz-card__info">
        <view class="biz-card__name">{{form.display_name || "企业名片"}}</view>
        <view class="biz-card__role">{{form.title || "职位未设置"}}</view>
        <view class="biz-card__contact">
          <view>{{form.mobile || "联系方式未公开"}}</view>
          <view>{{form.email || "邮箱未公开"}}</view>
        </view>
      </view>
      <view class="biz-card__avatar">{{form.display_name ? form.display_name[0] : "名"}}</view>
    </view>
  </view>

  <view class="card-actions">
    <view class="btn btn--sm btn--ghost" bindtap="login">企微登录</view>
    <view class="btn btn--sm btn--soft" bindtap="loadCard">
      <view class="icon icon-reload icon--sm"></view>
      <text>刷新</text>
    </view>
  </view>

  <view class="card">
    <text class="card__title">基础信息</text>
    <view class="field-row">
      <text class="field-row__label">姓名</text>
      <input class="field-row__value" value="{{form.display_name}}" data-key="display_name" bindinput="onInput" placeholder="请输入姓名" />
    </view>
    <view class="field-row">
      <text class="field-row__label">职位</text>
      <input class="field-row__value" value="{{form.title}}" data-key="title" bindinput="onInput" placeholder="请输入职位" />
    </view>
  </view>

  <view class="card">
    <text class="card__title">联系方式</text>
    <view class="field-row">
      <text class="field-row__label">手机</text>
      <input class="field-row__value" value="{{form.mobile}}" data-key="mobile" type="number" bindinput="onInput" placeholder="未填写" />
    </view>
    <view class="field-row">
      <text class="field-row__label">邮箱</text>
      <input class="field-row__value" value="{{form.email}}" data-key="email" bindinput="onInput" placeholder="未填写" />
    </view>
    <view class="field-row">
      <text class="field-row__label">微信号</text>
      <input class="field-row__value" value="{{form.wechat_id}}" data-key="wechat_id" bindinput="onInput" placeholder="未填写" />
    </view>
  </view>

  <view class="card share-note" wx:if="{{sharePath}}">
    <text class="card__more">分享路径</text>
    <view class="share-note__path">{{sharePath}}</view>
  </view>
</view>

<view class="fixed-footer">
  <view class="btn btn--ghost card-footer__item {{submitting ? 'btn--disabled' : ''}}" bindtap="saveCard">
    {{submitting ? '保存中…' : '保存'}}
  </view>
  <view class="btn btn--primary card-footer__item {{submitting ? 'btn--disabled' : ''}}" bindtap="createShare">
    <view class="icon icon-send icon--sm"></view>
    <text>{{submitting ? '生成中…' : '发名片'}}</text>
  </view>
</view>
