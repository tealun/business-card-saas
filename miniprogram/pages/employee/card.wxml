<view class="page">
  <view class="panel">
    <view class="eyebrow">EMPLOYEE</view>
    <view class="title">{{card.display_name || '企业名片'}}</view>
    <view class="muted">{{card.title || '未设置职位'}} · {{card.company || 'Demo Tenant'}}</view>
    <view class="button-row">
      <button bindtap="login">企微登录</button>
      <button class="secondary" bindtap="loadCard">刷新</button>
    </view>
  </view>

  <view class="panel">
    <label class="field">
      <text>姓名</text>
      <input value="{{form.display_name}}" data-key="display_name" bindinput="onInput" />
    </label>
    <label class="field">
      <text>职位</text>
      <input value="{{form.title}}" data-key="title" bindinput="onInput" />
    </label>
    <label class="field">
      <text>手机</text>
      <input value="{{form.mobile}}" data-key="mobile" bindinput="onInput" />
    </label>
    <label class="field">
      <text>邮箱</text>
      <input value="{{form.email}}" data-key="email" bindinput="onInput" />
    </label>
    <label class="field">
      <text>微信号</text>
      <input value="{{form.wechat_id}}" data-key="wechat_id" bindinput="onInput" />
    </label>
    <view class="button-row">
      <button bindtap="saveCard">保存</button>
      <button class="secondary" bindtap="createShare">分享</button>
    </view>
  </view>

  <view class="panel" wx:if="{{sharePath}}">
    <view class="eyebrow">SHARE</view>
    <view class="output">{{sharePath}}</view>
  </view>
</view>
