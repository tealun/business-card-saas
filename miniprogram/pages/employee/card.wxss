.card-actions {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 0;
}

.card-actions .btn { gap: 8rpx; }
.field-row input.field-row__value { height: 60rpx; line-height: 60rpx; }

.share-note__path {
  margin-top: 12rpx;
  padding: 20rpx;
  border-radius: var(--r-chip);
  background: var(--bg-page);
  font-size: 22rpx;
  color: var(--text-secondary);
  word-break: break-all;
}

.fixed-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 20rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--divider);
  display: flex;
  gap: 16rpx;
  box-sizing: border-box;
}

.card-footer__item { flex: 1; }
