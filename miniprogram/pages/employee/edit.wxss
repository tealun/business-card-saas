.edit-page { padding-top: 24rpx; }

.edit-avatar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 112rpx;
  padding: 24rpx 0 8rpx;
}

.edit-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--brand-tint);
  color: var(--brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
}

.field-row--textarea { align-items: flex-start; }

.edit-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.edit-tags__add {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border: 2rpx dashed #c9ced6;
  border-radius: var(--r-chip);
  color: var(--text-secondary);
  font-size: 24rpx;
}

.edit-note {
  padding: 0 8rpx 24rpx;
  color: var(--text-tertiary);
  font-size: 24rpx;
  line-height: 1.6;
}

.fixed-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 20rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--divider);
  box-sizing: border-box;
}
