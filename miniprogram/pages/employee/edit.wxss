.edit-page { padding-top: 24rpx; }

.status-bar {
  margin: 0 0 20rpx;
  padding: 18rpx 22rpx;
  border-radius: var(--r-card);
  font-size: 24rpx;
  line-height: 1.5;
}

.status-bar--warning {
  color: #b54708;
  background: var(--warning-tint);
}

.skeleton-card {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.skeleton-line { width: 100%; height: 28rpx; }
.skeleton-line--short { width: 45%; }
.skeleton-line--name { width: 62%; height: 56rpx; }

.edit-avatar-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 112rpx;
  padding: 24rpx 0 8rpx;
}

.edit-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--brand-tint);
  color: var(--brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  overflow: hidden;
}

.edit-logo-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 104rpx;
  padding: 20rpx 0 8rpx;
  border-top: 1rpx solid var(--divider);
}

.edit-logo-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.edit-logo {
  width: 112rpx;
  height: 72rpx;
  border-radius: 14rpx;
  background: var(--bg-page);
  border: 1rpx solid var(--divider);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-sizing: border-box;
}

.edit-logo__img {
  width: 100%;
  height: 100%;
}

.edit-logo__empty {
  color: var(--text-tertiary);
  font-size: 22rpx;
}

.edit-avatar-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
}

.edit-avatar__img {
  width: 100%;
  height: 100%;
}

.field-row--locked {
  color: var(--text-tertiary);
}

.field-row--textarea { align-items: flex-start; }

.edit-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.edit-section-help {
  display: block;
  margin-top: 14rpx;
  color: var(--text-tertiary);
  font-size: 24rpx;
  line-height: 1.5;
}

.edit-note {
  padding: 0 8rpx 24rpx;
  color: var(--text-tertiary);
  font-size: 24rpx;
  line-height: 1.6;
}

.fixed-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 20rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--divider);
  box-sizing: border-box;
}
