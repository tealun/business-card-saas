.status-bar {
  margin-bottom: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.status-bar--warning {
  color: #b54708;
  background: var(--warning-tint);
  border: 1rpx solid #fbd9a5;
}

.status-bar--danger {
  color: var(--danger);
  background: var(--danger-tint);
  border: 1rpx solid #f7c2be;
}

.identity-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--r-card);
  background: var(--bg-surface);
  box-shadow: var(--shadow-card);
}

.identity-strip__main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.identity-strip__text {
  min-width: 0;
  flex: 1;
}

.identity-strip__name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.identity-strip__sub {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.identity-strip__btn {
  width: 112rpx;
  padding: 0;
  flex: none;
}

.skeleton-card {
  height: 432rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24rpx;
}

.skeleton-line { width: 100%; height: 28rpx; }
.skeleton-line--short { width: 45%; }
.skeleton-line--name { width: 62%; height: 56rpx; }

.home-card { margin-bottom: 24rpx; }
.avatar-img { width: 100%; height: 100%; }

.quick-bar {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
}

.quick-bar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}

.quick-bar__sep { width: 1rpx; height: 48rpx; background: var(--divider); }
.send-btn { margin-bottom: 24rpx; }

.tool-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
}

.tool-grid__item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.request-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 24rpx;
}

.request-item__avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #eef0f3;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.request-item__info { flex: 1; min-width: 0; }
.stat-row { display: flex; margin: 28rpx 0; }
.stat-row__item { flex: 1; text-align: center; }
.stat-row__num { font-size: 44rpx; font-weight: 700; }
.stat-row__label { margin-top: 6rpx; font-size: 24rpx; color: var(--text-secondary); }

.visitor-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

.visitor-item__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef0f3;
  flex-shrink: 0;
  overflow: hidden;
}

.visitor-item__avatar--exchanged,
.visitor-item__avatar--pending,
.visitor-item__avatar--none { background: #eef0f3; }
.visitor-item__info { flex: 1; min-width: 0; }
.visitor-item__right { display: flex; flex-direction: column; align-items: flex-end; gap: 8rpx; }
.visitor-item__time { font-size: 22rpx; color: var(--text-tertiary); }

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(26, 29, 31, 0.45);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease;
  z-index: 180;
}

.sheet-mask--show { opacity: 1; visibility: visible; }

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 88vh;
  overflow-y: auto;
  padding: 24rpx 32rpx calc(84rpx + env(safe-area-inset-bottom));
  background: var(--bg-surface);
  border-radius: var(--r-sheet) var(--r-sheet) 0 0;
  transform: translateY(120%);
  transition: transform 0.25s ease-out;
  z-index: 190;
  box-sizing: border-box;
}

.sheet--show { transform: translateY(0); }
.sheet__grab { width: 72rpx; height: 8rpx; margin: 0 auto 26rpx; border-radius: 4rpx; background: var(--divider); }
.sheet__head { margin-bottom: 26rpx; }
.sheet__head .card__title { font-size: 40rpx; font-weight: 500; }

.sheet__thumb {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  background: var(--bg-page);
  margin-bottom: 24rpx;
}

.share-current-card__icon {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
}

.share-current-card__info {
  flex: 1;
  min-width: 0;
}

.share-current-card__tag {
  flex: none;
  font-size: 24rpx;
  color: var(--brand);
}

.sheet__thumb-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sheet__thumb-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sheet__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 22rpx;
  margin-bottom: 22rpx;
}

.sheet__cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  height: 168rpx;
  border-radius: var(--r-card);
  font-size: 26rpx;
  color: var(--text-primary);
  border: 2rpx solid var(--divider);
}

.sheet__grid--share .sheet__cell--primary {
  height: 188rpx;
  align-items: flex-start;
  padding: 32rpx;
  box-sizing: border-box;
  background: var(--brand-tint);
  border-color: transparent;
  font-size: 0;
}

.sheet__grid--share .sheet__cell--primary .icon {
  width: 54rpx;
  height: 54rpx;
}

.sheet__cell-title {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.sheet__cell-desc {
  margin-top: -6rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.sheet__cell--secondary {
  height: 88rpx;
  flex-direction: row;
  gap: 16rpx;
  border-radius: 20rpx;
  background: var(--bg-surface);
}

.poster-preview {
  display: flex;
  gap: 28rpx;
  align-items: center;
  margin-top: 8rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: var(--bg-page);
}

.poster-preview--stack {
  align-items: flex-start;
}

.poster-card {
  width: 160rpx;
  height: 240rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  color: var(--text-primary);
  background: #fff;
  box-sizing: border-box;
  box-shadow: 0 10rpx 26rpx rgba(26, 29, 31, 0.08);
}

.poster-card__top {
  width: 100%;
  height: 72rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, var(--brand-deep), var(--brand));
}

.poster-card__name { margin-top: 20rpx; font-size: 22rpx; font-weight: 700; }
.poster-card__qr { width: 42rpx; height: 42rpx; margin-top: 56rpx; margin-left: auto; border-radius: 4rpx; background: var(--text-primary); }
.poster-card--large {
  width: 220rpx;
  height: 330rpx;
  flex: none;
}
.poster-card--large .poster-card__qr {
  width: 68rpx;
  height: 68rpx;
  margin-top: 96rpx;
}
.qr-preview {
  width: 220rpx;
  height: 220rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 10rpx 26rpx rgba(26, 29, 31, 0.08);
  box-sizing: border-box;
  flex: none;
}
.qr-preview image,
.qr-preview__placeholder {
  width: 100%;
  height: 100%;
}
.qr-preview__placeholder {
  border-radius: 12rpx;
  background:
    linear-gradient(90deg, var(--text-primary) 10rpx, transparent 10rpx) 0 0 / 36rpx 36rpx,
    linear-gradient(var(--text-primary) 10rpx, transparent 10rpx) 0 0 / 36rpx 36rpx,
    #f7f8fa;
}
.poster-preview__copy { flex: 1; line-height: 1.55; }
.poster-preview__title { font-size: 30rpx; font-weight: 500; color: var(--text-primary); }
.poster-preview__btn { width: 220rpx; height: 72rpx; margin-top: 20rpx; padding: 0; }

.preview-sheet--fullscreen {
  top: 0;
  bottom: 0;
  max-height: none;
  padding: calc(36rpx + env(safe-area-inset-top)) 36rpx calc(56rpx + env(safe-area-inset-bottom));
  border-radius: 0;
  display: flex;
  flex-direction: column;
  background: var(--bg-page);
}

.preview-sheet--fullscreen .sheet__grab {
  display: none;
}

.preview-sheet--fullscreen .sheet__head {
  flex: none;
  margin-bottom: 28rpx;
}

.preview-sheet--fullscreen .poster-preview {
  flex: 1;
  min-height: 0;
  width: 100%;
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
}

.preview-sheet--fullscreen .poster-card--large {
  width: 440rpx;
  height: 640rpx;
  padding: 34rpx;
  border-radius: 28rpx;
}

.preview-sheet--fullscreen .poster-card--large .poster-card__top {
  height: 150rpx;
}

.preview-sheet--fullscreen .poster-card--large .poster-card__name {
  margin-top: 40rpx;
  font-size: 36rpx;
}

.preview-sheet--fullscreen .poster-card--large .poster-card__qr {
  width: 116rpx;
  height: 116rpx;
  margin-top: 210rpx;
}

.preview-sheet--fullscreen .qr-preview {
  width: 420rpx;
  height: 420rpx;
  padding: 28rpx;
  border-radius: 28rpx;
}

.preview-sheet--fullscreen .poster-preview__copy {
  flex: none;
  width: 100%;
  text-align: center;
}

.sheet__tip {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.5;
}

.identity-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.identity-option {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  border: 2rpx solid var(--divider);
  border-radius: var(--r-card);
  background: var(--bg-surface);
}

.identity-option--active {
  border-color: var(--brand);
  background: var(--brand-tint);
}

.identity-option__avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #eef0f3;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  overflow: hidden;
}

.identity-option__body {
  min-width: 0;
  flex: 1;
}

.identity-option__top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.identity-option__name {
  min-width: 0;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.identity-option__sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.identity-option__check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background-color: var(--brand);
  background-size: 28rpx 28rpx;
  flex: none;
}
