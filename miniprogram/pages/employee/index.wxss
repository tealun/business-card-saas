.status-bar {
  margin-bottom: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.status-bar--warning {
  color: #b54708;
  background: var(--warning-tint);
  border: 1rpx solid #fbd9a5;
}

.skeleton-card {
  height: 432rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24rpx;
}

.skeleton-line { width: 100%; height: 28rpx; }
.skeleton-line--short { width: 45%; }
.skeleton-line--name { width: 62%; height: 56rpx; }

.home-card { margin-bottom: 24rpx; }
.avatar-img { width: 100%; height: 100%; }

.quick-bar {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
}

.quick-bar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}

.quick-bar__sep { width: 1rpx; height: 48rpx; background: var(--divider); }
.send-btn { margin-bottom: 24rpx; }

.tool-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
}

.tool-grid__item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.request-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 24rpx;
}

.request-item__avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--brand-tint);
  color: var(--brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.request-item__info { flex: 1; min-width: 0; }
.stat-row { display: flex; margin: 28rpx 0; }
.stat-row__item { flex: 1; text-align: center; }
.stat-row__num { font-size: 44rpx; font-weight: 700; }
.stat-row__label { margin-top: 6rpx; font-size: 24rpx; color: var(--text-secondary); }

.visitor-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

.visitor-item__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}

.visitor-item__avatar--exchanged { background: var(--success); }
.visitor-item__avatar--pending { background: var(--warning); }
.visitor-item__avatar--none { background: var(--text-tertiary); }
.visitor-item__info { flex: 1; min-width: 0; }
.visitor-item__right { display: flex; flex-direction: column; align-items: flex-end; gap: 8rpx; }
.visitor-item__time { font-size: 22rpx; color: var(--text-tertiary); }

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(26, 29, 31, 0.45);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s ease;
  z-index: 50;
}

.sheet-mask--show { opacity: 1; visibility: visible; }

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  background: var(--bg-surface);
  border-radius: var(--r-sheet) var(--r-sheet) 0 0;
  transform: translateY(100%);
  transition: transform 0.25s ease-out;
  z-index: 60;
}

.sheet--show { transform: translateY(0); }
.sheet__grab { width: 72rpx; height: 8rpx; margin: 0 auto 24rpx; border-radius: 4rpx; background: var(--divider); }
.sheet__head { margin-bottom: 24rpx; }

.sheet__thumb {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 24rpx;
  border-radius: var(--r-card);
  background: var(--bg-page);
  margin-bottom: 24rpx;
}

.sheet__thumb-title { font-size: 30rpx; font-weight: 500; }
.sheet__thumb-sub { font-size: 24rpx; color: var(--text-secondary); }

.sheet__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.sheet__cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  height: 168rpx;
  border-radius: var(--r-card);
  font-size: 26rpx;
  color: var(--text-primary);
  border: 2rpx solid var(--divider);
}

.sheet__cell--primary { background: var(--brand-tint); border-color: transparent; }

.poster-preview {
  display: flex;
  gap: 20rpx;
  align-items: center;
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: var(--r-card);
  background: var(--bg-page);
}

.poster-card {
  width: 132rpx;
  height: 192rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  color: #fff;
  background: linear-gradient(160deg, var(--brand-deep), var(--brand));
  box-sizing: border-box;
}

.poster-card__top { font-size: 18rpx; opacity: 0.85; }
.poster-card__name { margin-top: 22rpx; font-size: 32rpx; font-weight: 700; }
.poster-card__qr { width: 52rpx; height: 52rpx; margin-top: 30rpx; border-radius: 8rpx; background: #fff; }
.poster-preview__copy { flex: 1; line-height: 1.6; }

.sheet__tip {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.5;
}
