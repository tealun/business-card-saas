<view class="public-page {{isOwnCard ? 'public-page--own' : ''}}" style="{{themeStyle}}">
  <view class="public-nav-title">企业名片</view>

  <block wx:if="{{uiState === 'loading'}}">
    <view class="public-body">
      <view class="card skeleton-card">
        <view class="skeleton skeleton-line skeleton-line--short"></view>
        <view class="skeleton skeleton-line skeleton-line--name"></view>
        <view class="skeleton skeleton-line"></view>
      </view>
    </view>
  </block>

  <block wx:elif="{{uiState === 'error'}}">
    <view class="state-full">
      <view class="state-full__mark"><view class="icon icon-reload icon--lg"></view></view>
      <view class="f18 bold">加载失败</view>
      <view class="f14 t-secondary state-full__desc">网络异常或名片不存在，请稍后重试。</view>
      <view class="btn btn--ghost btn--sm" bindtap="reload">重新加载</view>
    </view>
  </block>

  <block wx:else>
    <view class="public-body">
      <view class="disabled-bar" wx:if="{{isDisabled}}">该名片已停用，内容仅供历史识别。</view>

      <view class="biz-card public-name-card {{cardTemplateClass}}" style="{{cardBackgroundStyle}}">
        <view class="biz-card__head">
          <view class="biz-card__logo">
            <image class="biz-card__logo-img biz-card__logo-img--color" src="/assets/logo/color-nobg.png" mode="aspectFit" />
            <image class="biz-card__logo-img biz-card__logo-img--white" src="/assets/logo/white-nobg.png" mode="aspectFit" />
          </view>
          <text class="biz-card__company">{{card.card.company || card.company_profile.name || "企业名片"}}</text>
        </view>
        <view class="biz-card__body">
          <view class="biz-card__info">
            <view class="biz-card__name">{{card.card.display_name || "名片"}}</view>
            <view class="biz-card__role">{{card.card.title || "职位未设置"}}</view>
            <view class="biz-card__contact">
              <view wx:if="{{card.card.fields.mobile || card.card.fields.phone}}">{{card.card.fields.mobile || card.card.fields.phone}}</view>
              <view wx:if="{{card.card.fields.email}}">{{card.card.fields.email}}</view>
              <view wx:if="{{card.card.fields.address}}">{{card.card.fields.address}}</view>
            </view>
          </view>
          <view class="biz-card__avatar">
            <image wx:if="{{card.card.avatar_url}}" src="{{card.card.avatar_url}}" mode="aspectFill" class="avatar-img" />
            <view wx:else class="avatar-placeholder"></view>
          </view>
        </view>
        <view class="biz-card__status">
          <text wx:if="{{card.status === 'active'}}" class="badge badge--success">正常展示中</text>
          <text wx:else class="badge badge--warning">当前不可用</text>
        </view>
      </view>

      <view class="card interact-card">
        <view class="interact-card__metric">
          <view class="interact-card__num">{{viewCount}}</view>
          <view class="interact-card__label">访客</view>
        </view>
        <view class="interact-card__metric">
          <view class="interact-card__num">{{visitCount}}</view>
          <view class="interact-card__label">展示次数</view>
        </view>
        <view class="interact-card__like {{likedByMe ? 'interact-card__like--active' : ''}}" bindtap="likeCard">
          <view class="icon icon-like icon--sm"></view>
          <text>靠谱 {{likeCount}}</text>
        </view>
      </view>

      <view class="card public-cta-card" wx:if="{{!isOwnCard}}">
        <view class="btn btn--primary public-cta-card__item" bindtap="saveContact">保存到手机</view>
        <view wx:if="{{loggedIn}}" class="btn btn--soft public-cta-card__item" bindtap="exchangeCard">交换名片</view>
        <view wx:else class="btn btn--soft public-cta-card__item" bindtap="makeMyCard">我也做一个</view>
      </view>

      <view class="card action-grid">
        <view class="action-grid__item" bindtap="callPhone"><view class="icon icon-phone"></view><text>手机号</text></view>
        <view class="action-grid__item" bindtap="copyEmail"><view class="icon icon-mail"></view><text>发邮件</text></view>
        <view class="action-grid__item" bindtap="openMap"><view class="icon icon-location"></view><text>去拜访</text></view>
        <view class="action-grid__item" bindtap="copyWechat"><view class="icon icon-wechat"></view><text>加微信</text></view>
        <view class="action-grid__item" bindtap="viewPaperCard"><view class="icon icon-paper"></view><text>纸质名片</text></view>
      </view>

      <view class="card service-card" wx:if="{{serviceItems.length}}">
        <view class="row-between section-head">
          <text class="card__title">产品与服务</text>
          <text class="card__more">企业维护</text>
        </view>
        <view class="service-grid">
          <view class="service-item" wx:for="{{serviceItems}}" wx:key="title">
            <view class="service-item__icon">{{index + 1}}</view>
            <view class="service-item__title">{{item.title}}</view>
            <view class="service-item__desc">{{item.desc}}</view>
          </view>
        </view>
      </view>

      <view class="card intro-card" wx:if="{{introBlocks.length}}">
        <view class="row-between section-head">
          <text class="card__title">业务介绍</text>
          <text class="card__more">内容由企业维护</text>
        </view>
        <block wx:for="{{introBlocks}}" wx:key="index">
          <view class="intro-text" wx:if="{{item.type !== 'image'}}">{{item.text}}</view>
          <view class="intro-image" wx:else bindtap="previewIntroImage" data-url="{{item.image_url}}">
            <image wx:if="{{item.image_url}}" src="{{item.image_url}}" mode="aspectFill" />
            <view wx:else class="intro-image__ph">{{item.caption || "业务介绍图片"}}</view>
          </view>
        </block>
      </view>

      <view class="powered">由 智云名片 提供技术支持</view>
    </view>
  </block>
</view>
