<view class="public-page {{isOwnCard ? 'public-page--own' : ''}}" style="{{themeStyle}}">
  <view class="public-nav-home" bindtap="goHome">
    <view class="icon icon-home icon--sm"></view>
  </view>
  <view class="public-nav-title">{{navTitle || "名片"}}</view>

  <block wx:if="{{uiState === 'loading'}}">
    <view class="public-body">
      <view class="card skeleton-card">
        <view class="skeleton skeleton-line skeleton-line--short"></view>
        <view class="skeleton skeleton-line skeleton-line--name"></view>
        <view class="skeleton skeleton-line"></view>
      </view>
    </view>
  </block>

  <block wx:elif="{{uiState === 'error'}}">
    <view class="state-full">
      <view class="state-full__mark"><view class="icon icon-reload icon--lg"></view></view>
      <view class="f18 bold">加载失败</view>
      <view class="f14 t-secondary state-full__desc">网络异常或名片不存在，请稍后重试。</view>
      <view class="btn btn--ghost btn--sm" bindtap="reload">重新加载</view>
    </view>
  </block>

  <block wx:else>
    <view class="public-body">
      <view class="disabled-bar" wx:if="{{isDisabled}}">该名片已停用，内容仅供历史识别。</view>

      <view class="biz-card public-name-card {{cardTemplateClass}} {{showCardHead ? '' : 'biz-card--no-head'}}" style="{{cardBackgroundStyle}}">
        <view class="biz-card__head" wx:if="{{showCardHead}}">
          <view class="biz-card__logo" wx:if="{{cardLogoUrl}}">
            <image class="biz-card__logo-img" src="{{cardLogoUrl}}" mode="aspectFit" />
          </view>
          <text class="biz-card__company" wx:if="{{cardCompanyShortName}}">{{cardCompanyShortName}}</text>
        </view>
        <view class="biz-card__body">
          <view class="biz-card__info">
            <view class="biz-card__company-full" wx:if="{{cardCompanyName}}">{{cardCompanyName}}</view>
            <view class="biz-card__name">{{card.card.display_name || "名片"}}</view>
            <view class="biz-card__role" wx:if="{{card.card.title}}">{{card.card.title}}</view>
            <view class="biz-card__contact">
              <view wx:if="{{card.card.fields.mobile || card.card.fields.phone}}">{{card.card.fields.mobile || card.card.fields.phone}}</view>
              <view wx:if="{{card.card.fields.email}}">{{card.card.fields.email}}</view>
              <view wx:if="{{card.card.fields.address}}">{{card.card.fields.address}}</view>
            </view>
          </view>
          <view class="biz-card__avatar" wx:if="{{card.show_avatar}}">
            <image wx:if="{{card.card.avatar_url}}" src="{{card.card.avatar_url}}" mode="aspectFill" class="avatar-img" />
            <view wx:else class="avatar-placeholder"></view>
          </view>
        </view>
        <view class="biz-card__status" wx:if="{{card.status !== 'active'}}">
          <text class="badge badge--warning">当前不可用</text>
        </view>
        <view class="biz-card__type-corner biz-card__type-corner--interactive" catchtap="openIdentityInfo">
          <view class="icon {{cardCompanyName ? 'icon-building' : 'icon-person'}}"></view>
        </view>
      </view>

      <view class="card interact-card">
        <view class="visitor-avatars">
          <view class="visitor-avatar" wx:for="{{visitorAvatarSlots}}" wx:key="index">
            <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" mode="aspectFill" class="avatar-img" />
            <view wx:else class="avatar-placeholder"></view>
          </view>
        </view>
        <view class="interact-card__views">{{viewCount}} 人看过</view>
        <view class="interact-card__like {{likedByMe ? 'interact-card__like--active' : ''}}" bindtap="likeCard">
          <view class="icon icon-like icon--sm"></view>
          <text>靠谱 {{likeCount}}</text>
        </view>
      </view>

      <view class="card public-cta-card" wx:if="{{!isDisabled}}">
        <button wx:if="{{isOwnCard}}" class="btn btn--primary public-cta-card__item public-cta-card__button" open-type="share" bindtap="refreshShareImage">分享给好友</button>
        <view wx:if="{{isOwnCard}}" class="btn btn--soft public-cta-card__item" bindtap="editMyCard">修改信息</view>
        <view wx:if="{{!isOwnCard && isDemo}}" class="btn btn--primary public-cta-card__item" bindtap="openContactService">联系开通</view>
        <view wx:if="{{!isOwnCard && !isDemo}}" class="btn btn--primary public-cta-card__item" bindtap="saveContact">保存到手机</view>
        <view wx:if="{{!isOwnCard && loggedIn}}" class="btn btn--soft public-cta-card__item" bindtap="exchangeCard">交换名片</view>
        <view wx:if="{{!isOwnCard && !loggedIn}}" class="btn btn--soft public-cta-card__item" bindtap="makeMyCard">我也做一个</view>
      </view>

      <button wx:if="{{!isDisabled && !isOwnCard && canShare}}" class="btn btn--soft btn--block public-share-button" open-type="share" bindtap="refreshShareImage">
        <view class="icon icon-forward icon--sm"></view>
        <text>分享给好友</text>
      </button>

      <view class="card action-grid">
        <view class="action-grid__item" bindtap="callPhone"><view class="icon icon-phone"></view><text>手机号</text></view>
        <view class="action-grid__item" bindtap="copyEmail"><view class="icon icon-mail"></view><text>发邮件</text></view>
        <view class="action-grid__item" bindtap="openMap"><view class="icon icon-location"></view><text>去拜访</text></view>
        <view class="action-grid__item" bindtap="copyWechat"><view class="icon icon-wechat"></view><text>加微信</text></view>
        <view class="action-grid__item" bindtap="viewPaperCard"><view class="icon icon-paper"></view><text>纸质名片</text></view>
      </view>

      <company-module wx:for="{{displayModules}}" wx:key="key" module="{{item}}" bindpreview="previewModuleImage" />

      <view class="card upgrade-card" wx:if="{{isDemo}}">
        <view class="upgrade-card__copy">
          <view class="card__title">也想拥有这样的企业名片？</view>
          <view class="upgrade-card__desc">统一企业形象、员工名片与访客转化数据。</view>
        </view>
        <view class="btn btn--sm upgrade-card__action" bindtap="openUpgradeEnterprise">查看流程</view>
      </view>

      <view class="powered">由 智云名片 提供技术支持</view>
    </view>
  </block>

  <view class="sheet-mask {{wechatSheetVisible ? 'sheet-mask--show' : ''}}" catchtap="closeWechatSheet"></view>
  <view class="sheet {{wechatSheetVisible ? 'sheet--show' : ''}}">
    <view class="sheet__grab"></view>
    <view class="row-between sheet__head">
      <text class="card__title">加微信</text>
      <view class="icon icon-close icon--sm" catchtap="closeWechatSheet"></view>
    </view>
    <view class="wechat-qr">
      <image wx:if="{{wechatQrUrl}}" src="{{wechatQrUrl}}" mode="aspectFit" />
      <view wx:else class="wechat-qr__placeholder"></view>
      <view class="wechat-qr__tip">长按识别加微信</view>
    </view>
  </view>

  <canvas id="shareCardCanvas" type="2d" class="share-card-canvas"></canvas>
</view>
