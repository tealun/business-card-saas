.public-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero {
  position: relative;
  padding-bottom: 48rpx;
  color: #fff;
  overflow: hidden;
  background:
    radial-gradient(circle at 24rpx 24rpx, rgba(255,255,255,.18) 0 2rpx, transparent 3rpx) 0 0 / 32rpx 32rpx,
    linear-gradient(160deg, var(--brand-deep), var(--brand) 70%, #3d7bff);
}

.hero--disabled {
  background:
    radial-gradient(circle at 24rpx 24rpx, rgba(255,255,255,.14) 0 2rpx, transparent 3rpx) 0 0 / 32rpx 32rpx,
    linear-gradient(160deg, #5a6270, #7a828f);
}

.hero--skeleton {
  min-height: 360rpx;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero__nav {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.hero__back { filter: brightness(0) invert(1); }
.hero__nav-title { position: absolute; left: 50%; transform: translateX(-50%); font-size: 36rpx; font-weight: 500; }
.hero__menu { width: 48rpx; height: 48rpx; }

.hero__company {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 44rpx 0;
  font-size: 26rpx;
  font-weight: 500;
}

.hero__logo {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: rgba(255,255,255,.9);
}

.hero__main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 36rpx 44rpx 0;
}

.hero__text { flex: 1; min-width: 0; }
.hero__name { font-size: 52rpx; font-weight: 700; line-height: 1.15; }
.hero__role { margin-top: 8rpx; font-size: 28rpx; color: rgba(255,255,255,.86); }
.hero__contact { margin-top: 28rpx; font-size: 26rpx; line-height: 1.7; color: rgba(255,255,255,.86); }

.hero__avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--brand);
  font-size: 48rpx;
  font-weight: 700;
  border: 4rpx solid rgba(255,255,255,.5);
  overflow: hidden;
}

.avatar-img { width: 100%; height: 100%; }
.public-body { padding: 24rpx 32rpx 0; }

.disabled-bar {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  color: #b54708;
  background: var(--warning-tint);
  border: 1rpx solid #fbd9a5;
  font-size: 26rpx;
}

.interact {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 28rpx 32rpx;
}

.interact__stat { font-size: 24rpx; color: var(--text-secondary); }
.interact__badges { display: flex; gap: 8rpx; flex-wrap: wrap; justify-content: flex-end; }

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  row-gap: 28rpx;
  padding: 32rpx 8rpx;
}

.action-grid__item {
  min-height: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.action-grid__btn { font-size: 24rpx; color: var(--text-secondary); }

.intro-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-primary);
}

.intro-imgs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.intro-imgs__ph,
.honor-card__img {
  height: 192rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #c9ced6;
  background: var(--bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  font-size: 24rpx;
}

.intro-expand {
  margin-top: 24rpx;
  text-align: center;
  color: var(--brand);
  font-size: 26rpx;
}

.video-player {
  position: relative;
  height: 352rpx;
  margin-top: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #1a1d1f, #3a4048);
  display: flex;
  align-items: center;
  justify-content: center;
}

.video-player__label {
  position: absolute;
  left: 24rpx;
  top: 20rpx;
  padding: 6rpx 16rpx;
  border: 1rpx dashed rgba(255,255,255,.45);
  border-radius: 12rpx;
  color: rgba(255,255,255,.7);
  font-size: 22rpx;
}

.video-player__play {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.video-player__play .icon { filter: none; background-color: var(--brand); border-radius: 50%; }
.video-player__time {
  position: absolute;
  right: 20rpx;
  bottom: 16rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(0,0,0,.5);
  color: #fff;
  font-size: 22rpx;
}

.video-title { margin-top: 16rpx; }
.honor-section { padding-right: 0; }
.honor-head { padding-right: 32rpx; }
.honor-desc { margin-top: 16rpx; padding-right: 32rpx; color: var(--text-secondary); font-size: 26rpx; line-height: 1.6; }
.honor-scroll { margin-top: 20rpx; white-space: nowrap; }

.honor-card {
  display: inline-block;
  width: 280rpx;
  margin-right: 20rpx;
  vertical-align: top;
}

.honor-card__title { margin-top: 16rpx; font-size: 26rpx; font-weight: 500; }
.honor-card__sub { margin-top: 6rpx; font-size: 24rpx; color: var(--text-tertiary); white-space: normal; }

.powered {
  padding: 4rpx 0 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.public-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid var(--divider);
  box-sizing: border-box;
  z-index: 30;
}

.public-footer__icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  border: 2rpx solid var(--divider);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: var(--text-secondary);
  font-size: 18rpx;
  box-sizing: border-box;
}

.public-footer__btn { color: var(--text-secondary); }
.public-footer__save,
.public-footer__cta { flex: 1; min-width: 0; }
