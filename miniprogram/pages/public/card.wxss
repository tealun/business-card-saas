.public-page {
  position: relative;
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow: hidden;
}

.public-page::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: calc(360rpx + env(safe-area-inset-top));
  background:
    radial-gradient(circle, rgba(255, 255, 255, 0.34) 1rpx, rgba(255, 255, 255, 0) 2rpx),
    linear-gradient(180deg, rgba(0, 0, 0, 0.38), rgba(0, 0, 0, 0.2)),
    linear-gradient(135deg, var(--brand-deep) 0%, var(--brand) 52%, var(--brand-soft) 100%);
  background-size: 30rpx 30rpx, auto, auto;
  pointer-events: none;
}

.public-nav-title {
  position: absolute;
  left: 160rpx;
  right: 160rpx;
  top: calc(env(safe-area-inset-top) + 92rpx);
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
  z-index: 2;
  pointer-events: none;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.public-body {
  position: relative;
  z-index: 1;
  padding: calc(200rpx + env(safe-area-inset-top)) 28rpx 0;
}

.public-name-card {
  margin-bottom: 20rpx;
  box-shadow: 0 22rpx 54rpx rgba(26, 29, 31, 0.16);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.disabled-bar {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  color: #b54708;
  background: var(--warning-tint);
  font-size: 26rpx;
}

.interact-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 28rpx;
}

.visitor-avatars {
  display: flex;
  align-items: center;
}

.visitor-avatar {
  width: 48rpx;
  height: 48rpx;
  margin-left: -10rpx;
  border: 4rpx solid #fff;
  border-radius: 50%;
  background: #eef0f3;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.visitor-avatar:first-child {
  margin-left: 0;
}

.visitor-avatar--img {
  background: #eef0f3;
}

.interact-card__views {
  flex: 1;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.interact-card__views::after {
  content: "";
  display: none;
}

.interact-card__label {
  color: var(--text-secondary);
  font-size: 24rpx;
}

.interact-card__like {
  min-width: 152rpx;
  height: 56rpx;
  padding: 0 22rpx;
  border: 2rpx solid var(--divider);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  box-sizing: border-box;
}

.interact-card__like .icon-like {
  background-color: var(--text-tertiary);
}

.interact-card__like--active {
  color: var(--brand);
  border-color: var(--brand);
  background: var(--brand-tint);
}

.interact-card__like--active .icon-like {
  background-color: var(--brand);
}

.public-cta-card {
  display: flex;
  gap: 18rpx;
  padding: 24rpx;
}

.public-cta-card__item {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
}

.public-cta-card__button {
  margin: 0;
  padding: 0;
  border: 0;
  line-height: 88rpx;
}

.public-cta-card__button::after {
  border: 0;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
  padding: 28rpx 10rpx;
}

.action-grid__item {
  min-width: 0;
  min-height: 104rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: var(--text-primary);
  font-size: 24rpx;
}

.section-head {
  margin-bottom: 24rpx;
}

.service-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.service-item {
  min-height: 164rpx;
  padding: 18rpx 12rpx;
  border-radius: 18rpx;
  background: var(--bg-page);
  box-sizing: border-box;
}

.service-item__icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: var(--brand);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.service-item__title {
  margin-top: 14rpx;
  color: var(--text-primary);
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.25;
}

.service-item__desc {
  margin-top: 6rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
  line-height: 1.35;
}

.intro-text {
  margin-top: 20rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.75;
}

.intro-image {
  height: 360rpx;
  margin-top: 24rpx;
  border-radius: 18rpx;
  overflow: hidden;
  background: var(--bg-page);
}

.intro-image image {
  width: 100%;
  height: 100%;
}

.intro-image__ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  font-size: 26rpx;
}

.powered {
  padding: 4rpx 0 28rpx;
  text-align: center;
  color: var(--text-tertiary);
  font-size: 22rpx;
}

.receive-panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 30;
  padding: 30rpx 28rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 12rpx 48rpx rgba(16, 24, 40, 0.14);
  box-sizing: border-box;
}

.receive-panel__hello {
  color: var(--text-primary);
  font-size: 36rpx;
  font-weight: 500;
  line-height: 1.25;
}

.receive-panel__sub {
  margin-top: 10rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.receive-panel__actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 24rpx;
}

.receive-panel__secondary {
  width: 128rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: var(--brand);
  font-size: 24rpx;
  font-weight: 500;
  flex: none;
}

.receive-panel__primary {
  flex: 1;
}

.agreement {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding-bottom: 4rpx;
  text-align: center;
  color: var(--text-tertiary);
  font-size: 20rpx;
  pointer-events: none;
}

.skeleton-card {
  height: 432rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24rpx;
}

.skeleton-line {
  width: 100%;
  height: 28rpx;
}

.skeleton-line--short {
  width: 45%;
}

.skeleton-line--name {
  width: 62%;
  height: 56rpx;
}
