.login-page{min-height:100vh;padding:48rpx 28rpx;background:#f4f6fa;box-sizing:border-box}.login-card{background:#fff;border-radius:28rpx;padding:40rpx;box-shadow:0 18rpx 50rpx rgba(37,50,92,.1)}.title{font-size:38rpx;font-weight:700;color:#182033;margin-bottom:28rpx}.hint{color:#697386;line-height:1.7;margin:18rpx 0}.error{color:#c33;padding:20rpx;background:#fff2f2;border-radius:16rpx}.success{color:#16794b;padding:24rpx;background:#effaf5;border-radius:16rpx;line-height:1.7}.tenant-button{margin-top:18rpx;background:#4e5fc7;color:#fff;border-radius:16rpx}
