<view class="login-page"><view class="login-card"><view class="title">企业后台登录确认</view><view wx:if="{{loading}}" class="hint">正在验证微信账号和管理员权限…</view><view wx:if="{{error}}" class="error">{{error}}</view><view wx:if="{{success}}" class="success">{{success}}</view><block wx:if="{{tenants.length}}"><view class="hint">请选择本次要管理的企业</view><button wx:for="{{tenants}}" wx:key="tenant_id" data-id="{{item.tenant_id}}" bindtap="choose" class="tenant-button">{{item.tenant_name}} · {{item.role}}</button></block></view></view>
