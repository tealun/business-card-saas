<view class="page wallet-page {{!loggedIn ? 'page--with-login' : ''}} tabbar-safe" style="{{themeStyle}}">
  <view class="status-bar status-bar--warning" wx:if="{{demoMode}}">
    当前访客与交换记录为演示样例，登录后会展示你的真实名片数据。
  </view>

  <view class="wallet-tabs">
    <view
      class="wallet-tab {{activeTab === item.key ? 'wallet-tab--active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="switchTab"
    >
      <text>{{item.label}}</text>
      <text class="wallet-tab__count">{{item.count}}</text>
    </view>
  </view>

  <view class="search-row" wx:if="{{activeTab !== 'offline'}}">
    <view class="search-box">
      <view class="icon icon-search icon--sm"></view>
      <input value="{{keyword}}" bindinput="onSearch" placeholder="搜索姓名/公司/职位" />
    </view>
    <view class="filter-btn"><view class="icon icon-filter icon--sm"></view></view>
  </view>

  <view class="offline-tools" wx:if="{{activeTab === 'offline'}}">
    <view class="offline-tool" bindtap="captureOfflineCard">
      <view class="icon icon-camera"></view>
      <view>
        <view class="offline-tool__title">拍照识别并保存</view>
        <view class="offline-tool__desc">识别纸质名片，保存为电子名片</view>
      </view>
    </view>
    <view class="offline-tool" bindtap="bindOfflineImage">
      <view class="icon icon-paper"></view>
      <view>
        <view class="offline-tool__title">绑定纸质图片</view>
        <view class="offline-tool__desc">为电子名片保留原始拍摄图片</view>
      </view>
    </view>
  </view>

  <view class="empty-card" wx:if="{{!groups.length}}">
    <view class="state-full__mark"><view class="icon {{activeTab === 'offline' ? 'icon-paper' : 'icon-contact'}} icon--lg"></view></view>
    <view class="f18 bold">{{activeTab === 'offline' ? '还没有线下名片' : '还没有名片记录'}}</view>
    <view class="f14 t-secondary">{{activeTab === 'offline' ? '拍照识别纸质名片后，会在这里形成电子名片。' : '发出第一张名片后，这里会沉淀访问与交换状态。'}}</view>
    <view class="btn btn--primary btn--sm" wx:if="{{activeTab === 'offline'}}" bindtap="captureOfflineCard">拍照识别</view>
    <view class="btn btn--primary btn--sm" wx:else bindtap="goSendCard">去发名片</view>
  </view>

  <block wx:for="{{groups}}" wx:key="title">
    <view class="group-title">{{item.title}}</view>
    <view class="card wallet-list">
      <view class="wallet-item" wx:for="{{item.items}}" wx:for-item="card" wx:key="id">
        <view class="wallet-item__avatar wallet-item__avatar--{{card.state}}">
          <image wx:if="{{card.avatarUrl}}" src="{{card.avatarUrl}}" mode="aspectFill" class="avatar-img" />
          <view wx:else class="avatar-placeholder"></view>
        </view>
        <view class="wallet-item__main">
          <view class="wallet-item__name">{{card.name}}</view>
          <view class="wallet-item__sub">{{card.title}}</view>
          <view class="wallet-item__meta" wx:if="{{card.meta}}">{{card.meta}}</view>
        </view>
        <view class="wallet-item__side">
          <text class="badge badge--success" wx:if="{{card.state === 'exchanged'}}">已交换</text>
          <text class="badge badge--warning" wx:elif="{{card.state === 'pending'}}">待通过</text>
          <view class="btn btn--sm btn--ghost" wx:elif="{{card.canExchange !== false && !card.isAnonymous}}" data-id="{{card.id}}" bindtap="exchange">交换</view>
          <text class="wallet-item__time">{{card.time}}</text>
        </view>
      </view>
    </view>
  </block>

  <login-bar wx:if="{{!loggedIn}}" text="立即登录，查看我的访客" bind:success="onLoginSuccess" />
</view>
