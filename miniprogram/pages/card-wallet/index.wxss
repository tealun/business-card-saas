.wallet-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid var(--divider);
}

.wallet-tab {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: baseline;
  gap: 6rpx;
  height: 80rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.wallet-tab--active {
  color: var(--brand);
  font-weight: 500;
}

.wallet-tab--active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 56rpx;
  height: 5rpx;
  border-radius: 3rpx;
  background: var(--brand);
  transform: translateX(-50%);
}

.wallet-tab__count { font-size: 22rpx; }

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-box {
  flex: 1;
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: var(--shadow-card);
}

.search-box input {
  flex: 1;
  font-size: 26rpx;
}

.filter-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-card);
}

.empty-card {
  min-height: 520rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  text-align: center;
}

.group-title {
  margin: 24rpx 4rpx 12rpx;
  color: var(--text-tertiary);
  font-size: 24rpx;
  font-weight: 500;
}

.wallet-list { padding: 0 24rpx; }

.wallet-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx 0;
}

.wallet-item + .wallet-item {
  border-top: 1rpx solid var(--divider);
}

.wallet-item__avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  flex: none;
}

.wallet-item__avatar--exchanged { background: var(--success); }
.wallet-item__avatar--pending { background: var(--warning); }
.wallet-item__avatar--none { background: var(--text-tertiary); }
.wallet-item__main { flex: 1; min-width: 0; }
.wallet-item__name { font-size: 30rpx; font-weight: 500; }
.wallet-item__sub { margin-top: 6rpx; font-size: 24rpx; color: var(--text-secondary); }
.wallet-item__meta { margin-top: 6rpx; font-size: 22rpx; color: var(--text-tertiary); }
.wallet-item__side { display: flex; flex-direction: column; align-items: flex-end; gap: 10rpx; }
.wallet-item__time { font-size: 22rpx; color: var(--text-tertiary); }
