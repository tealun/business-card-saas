/* 顶部 tab */
.wallet-tabs {
  display: flex;
  gap: 40rpx;
  padding: 8rpx 8rpx 24rpx;
}

.wallet-tab {
  position: relative;
  font-size: 28rpx;
  color: var(--text-secondary);
  padding-bottom: 12rpx;
}

.wallet-tab--active { color: var(--text-primary); font-weight: 700; }

.wallet-tab--active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--brand);
}

/* 搜索 */
.wallet-search { display: flex; gap: 16rpx; margin-bottom: 24rpx; }

.wallet-search__box {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: var(--r-btn);
  background: var(--bg-surface);
}

.wallet-search__box input { flex: 1; font-size: 26rpx; }

.wallet-search__filter {
  width: 76rpx;
  height: 76rpx;
  border-radius: var(--r-btn);
  background: var(--bg-surface);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 分组列表 */
.wallet-group-title {
  margin: 8rpx 8rpx 12rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.wallet-list { padding: 8rpx 32rpx; }

.wallet-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 0;
}

.wallet-item + .wallet-item { border-top: 1rpx solid var(--divider); }

.wallet-item__avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}

.wallet-item__avatar--exchanged { background: var(--success); }
.wallet-item__avatar--pending { background: var(--warning); }
.wallet-item__avatar--none { background: var(--text-tertiary); }
.wallet-item__info { flex: 1; }
.wallet-item__info view { line-height: 1.5; }
.wallet-item__right { display: flex; flex-direction: column; align-items: flex-end; gap: 10rpx; }
.wallet-item__time { font-size: 22rpx; color: var(--text-tertiary); }

/* 空态 */
.wallet-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding-top: 160rpx;
}

.wallet-empty__icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--bg-surface);
  background-size: 80rpx;
  opacity: 0.7;
  margin-bottom: 12rpx;
}
