.company-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(100rpx + 120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.company-hero {
  padding: 72rpx 32rpx 40rpx;
  color: #fff;
  text-align: center;
  background:
    radial-gradient(circle at 24rpx 24rpx, rgba(255,255,255,.18) 0 2rpx, transparent 3rpx) 0 0 / 32rpx 32rpx,
    linear-gradient(160deg, var(--brand-deep), var(--brand) 70%, #3d7bff);
}

.company-logo {
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto;
  border-radius: 32rpx;
  background: #fff;
  color: var(--brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 700;
}

.company-name {
  margin-top: 24rpx;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.company-badges {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 18rpx;
}

.company-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 36rpx;
  padding: 24rpx 0;
  border-radius: var(--r-card);
  background: rgba(255,255,255,.14);
}

.company-stat__num { font-size: 36rpx; font-weight: 700; }
.company-stat__label { margin-top: 6rpx; color: rgba(255,255,255,.78); font-size: 22rpx; }
.company-body { padding-top: 24rpx; }
.company-intro { margin-top: 24rpx; line-height: 1.7; font-size: 28rpx; }
.qual-row { margin-top: 24rpx; }
.team-card { padding-bottom: 16rpx; }
.dept-title { margin-top: 28rpx; color: var(--text-tertiary); font-size: 24rpx; font-weight: 500; }

.member-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 0;
}

.member-row + .member-row { border-top: 1rpx solid var(--divider); }

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--brand-tint);
  color: var(--brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  flex: none;
}

.member-main { flex: 1; min-width: 0; }
.member-name { display: flex; align-items: center; gap: 8rpx; font-size: 30rpx; font-weight: 500; }
.member-title { margin-top: 6rpx; font-size: 24rpx; color: var(--text-secondary); }

.company-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  background: #fff;
  border-top: 1rpx solid var(--divider);
  box-sizing: border-box;
  z-index: 99;
}

.company-footer__btn { flex: 1; }
