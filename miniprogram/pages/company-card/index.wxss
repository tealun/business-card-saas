.company-gateway {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
  background: var(--bg-page);
}

.company-gateway__loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  text-align: center;
}

.company-gateway__mark {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
}
