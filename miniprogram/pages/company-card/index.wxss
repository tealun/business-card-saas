.company-page {
  position: relative;
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(100rpx + 120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow: hidden;
}

.company-page::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: calc(360rpx + env(safe-area-inset-top));
  background:
    radial-gradient(circle, rgba(255, 255, 255, 0.34) 1rpx, rgba(255, 255, 255, 0) 2rpx),
    linear-gradient(180deg, rgba(0, 0, 0, 0.38), rgba(0, 0, 0, 0.2)),
    linear-gradient(135deg, var(--brand-deep) 0%, var(--brand) 52%, var(--brand-soft) 100%);
  background-size: 30rpx 30rpx, auto, auto;
  pointer-events: none;
}

.company-nav-title {
  position: absolute;
  left: 160rpx;
  right: 160rpx;
  top: calc(env(safe-area-inset-top) + 92rpx);
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
  z-index: 2;
  pointer-events: none;
}

.company-body {
  position: relative;
  z-index: 1;
  padding-top: calc(200rpx + env(safe-area-inset-top));
}

.company-preview-card {
  margin-bottom: 24rpx;
  box-shadow: 0 22rpx 54rpx rgba(26, 29, 31, 0.16);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.skeleton-card {
  height: 432rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24rpx;
}

.skeleton-line {
  width: 100%;
  height: 28rpx;
}

.skeleton-line--short {
  width: 45%;
}

.skeleton-line--name {
  width: 62%;
  height: 56rpx;
}

.status-card {
  padding: 28rpx;
  border-radius: var(--r-card);
  background: var(--bg-surface);
  box-shadow: var(--shadow-card);
}

.status-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.status-card__desc {
  margin: 14rpx 0 24rpx;
  font-size: 26rpx;
  line-height: 1.65;
  color: var(--text-secondary);
}

.personal-data-card__desc {
  margin-bottom: 0;
}

.company-stat-row {
  display: flex;
  margin: 28rpx 0 24rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid var(--divider);
  border-bottom: 1rpx solid var(--divider);
}

.company-stat-row__item {
  flex: 1;
  text-align: center;
}

.company-stat-row__num {
  color: var(--brand);
  font-size: 42rpx;
  font-weight: 700;
}

.company-stat-row__label {
  margin-top: 6rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.company-action-row {
  display: flex;
  gap: 16rpx;
}

.company-action-row__item {
  flex: 1;
}

.company-visitor-btn {
  margin-bottom: 20rpx;
}
