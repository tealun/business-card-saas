.company-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(100rpx + 120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.company-body {
  padding-top: 24rpx;
}

.company-preview-card {
  margin-bottom: 24rpx;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.skeleton-card {
  height: 432rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24rpx;
}

.skeleton-line {
  width: 100%;
  height: 28rpx;
}

.skeleton-line--short {
  width: 45%;
}

.skeleton-line--name {
  width: 62%;
  height: 56rpx;
}

.status-card {
  padding: 28rpx;
  border-radius: var(--r-card);
  background: var(--bg-surface);
  box-shadow: var(--shadow-card);
}

.status-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.status-card__desc {
  margin: 14rpx 0 24rpx;
  font-size: 26rpx;
  line-height: 1.65;
  color: var(--text-secondary);
}
