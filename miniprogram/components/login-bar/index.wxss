.login-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  z-index: 101;
  padding-bottom: 0;
}

.login-bar__btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  padding: 0;
  border: none;
  border-radius: 14rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  font-weight: 600;
  color: #ffffff;
  background: linear-gradient(135deg, #ff9a3d 0%, #f05a24 100%);
  box-shadow: 0 14rpx 34rpx rgba(240, 90, 36, 0.34);
}

.login-bar__btn::after {
  border: none;
}

.login-bar__arrow { font-size: 34rpx; font-weight: 400; transition: transform 160ms ease; }
.login-bar__btn:active { background: linear-gradient(135deg, #f78a2d 0%, #dc4a18 100%); }
.login-bar__btn:active .login-bar__arrow { transform: translateX(6rpx); }

.login-dialog__mask {
  position: fixed;
  inset: 0;
  z-index: 300;
  background: rgba(18, 23, 38, 0.48);
  animation: mask-in 180ms ease-out both;
}

.login-dialog {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(124rpx + env(safe-area-inset-bottom));
  z-index: 301;
  padding: 18rpx 36rpx 34rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  border-radius: 36rpx;
  box-sizing: border-box;
  background: radial-gradient(circle at 100% 0%, rgba(90, 112, 200, 0.12), transparent 42%), #ffffff;
  box-shadow: 0 30rpx 80rpx rgba(20, 30, 70, 0.22);
  animation: dialog-in 220ms cubic-bezier(0.22, 0.8, 0.3, 1) both;
}

.login-dialog__handle { width: 72rpx; height: 8rpx; margin: 0 auto 28rpx; border-radius: 99rpx; background: #dfe3eb; }
.login-dialog__heading { display: flex; align-items: center; }
.login-dialog__mark { width: 76rpx; height: 76rpx; margin-right: 22rpx; display: flex; align-items: center; justify-content: center; border-radius: 24rpx 24rpx 24rpx 8rpx; background: #eef1fb; }
.login-dialog__mark-core { width: 28rpx; height: 36rpx; border: 5rpx solid #5a70c8; border-top-width: 10rpx; border-radius: 5rpx; box-sizing: border-box; transform: rotate(-5deg); }
.login-dialog__heading-copy { flex: 1; min-width: 0; }
.login-dialog__eyebrow { margin-bottom: 5rpx; font-size: 21rpx; letter-spacing: 2rpx; color: #7c89bf; }
.login-dialog__title { font-size: 38rpx; line-height: 1.3; font-weight: 700; color: #171b2d; }
.login-dialog__close { width: 56rpx; height: 56rpx; line-height: 50rpx; text-align: center; font-size: 42rpx; font-weight: 300; color: #9299a8; }
.login-dialog__intro { margin: 26rpx 0 30rpx; padding: 22rpx 24rpx; border-radius: 20rpx; font-size: 25rpx; line-height: 1.65; color: #60697a; background: rgba(244, 246, 250, 0.88); }
.login-dialog__agreement { display: flex; align-items: flex-start; padding: 4rpx 2rpx 26rpx; }
.login-dialog__checkbox { width: 36rpx; height: 36rpx; margin: 2rpx 16rpx 0 0; flex: none; display: flex; align-items: center; justify-content: center; border: 2rpx solid #bdc4d2; border-radius: 10rpx; box-sizing: border-box; font-size: 24rpx; color: #fff; background: #fff; }
.login-dialog__checkbox--checked { border-color: #5a70c8; background: #5a70c8; }
.login-dialog__agreement-copy { flex: 1; font-size: 24rpx; line-height: 1.65; color: #737b8b; }
.login-dialog__link { color: #5268bd; font-weight: 500; }
.login-dialog__submit { width: 100%; height: 94rpx; line-height: 94rpx; border: none; border-radius: 22rpx; font-size: 30rpx; font-weight: 650; color: #fff; background: linear-gradient(135deg, #ff9a3d 0%, #f05a24 100%); box-shadow: 0 12rpx 30rpx rgba(240, 90, 36, 0.32); }
.login-dialog__submit::after { border: none; }
.login-dialog__submit:active { background: linear-gradient(135deg, #f78a2d 0%, #dc4a18 100%); }
.login-dialog__submit--loading { opacity: 0.76; }
.login-dialog__footnote { margin-top: 20rpx; text-align: center; font-size: 21rpx; line-height: 1.5; color: #a0a6b2; }
@keyframes mask-in { from { opacity: 0; } to { opacity: 1; } }
@keyframes dialog-in { from { opacity: 0; transform: translateY(36rpx) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
