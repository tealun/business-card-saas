.login-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  z-index: 101;
  padding-bottom: 0;
}

.login-bar__btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  padding: 0;
  border: none;
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #ffffff;
  background: linear-gradient(180deg, #f59e0b 0%, #ea580c 100%);
  box-shadow: 0 12rpx 28rpx rgba(245, 158, 11, 0.32);
}

.login-bar__btn::after {
  border: none;
}

.login-bar__btn--disabled {
  color: #ffffff;
  opacity: 0.7;
}
