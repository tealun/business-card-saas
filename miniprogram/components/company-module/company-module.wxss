.company-module {
  overflow: hidden;
  width: 100%;
  max-width: 100%;
}

.section-head {
  margin-bottom: 24rpx;
}

.service-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.service-grid--text {
  grid-template-columns: 1fr;
}

.service-grid--image {
  grid-template-columns: repeat(2, 1fr);
}

.service-item {
  min-height: 164rpx;
  padding: 18rpx 12rpx;
  border-radius: 18rpx;
  background: var(--bg-page);
  box-sizing: border-box;
}

.service-item__title {
  margin-top: 14rpx;
  color: var(--text-primary);
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.25;
}

.service-item__desc {
  margin-top: 6rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
  line-height: 1.35;
}

.module-enter {
  animation: module-enter 280ms ease-out both;
}

@keyframes module-enter {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.module-scroll {
  width: 100%;
  white-space: nowrap;
}

.module-scroll__track {
  display: inline-flex;
  gap: 18rpx;
  padding-right: 56rpx;
}

.service-item--media,
.honor-item {
  width: 420rpx;
  flex: none;
  white-space: normal;
}

.service-item image,
.honor-item image,
.gallery-image {
  width: 100%;
  height: 240rpx;
  border-radius: 16rpx;
  background: #f2f4f7;
}

.gallery-image {
  width: 560rpx;
  flex: none;
}

.company-video-list {
  display: grid;
  gap: 18rpx;
}

.company-video-shell {
  width: 100%;
  max-width: 100%;
  overflow: hidden;
  border-radius: 18rpx;
}

.company-module .company-video {
  width: 100%;
  max-width: 100%;
  height: 390rpx;
  border-radius: 18rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.company-module .intro-video-card__video {
  display: block;
  width: 100%;
  height: 360rpx;
  border-radius: 0;
  background: #0f172a;
}

.company-module .company-video-cover {
  position: relative;
  display: block;
  background: #0f172a;
}

.company-video-cover__image,
.company-video-cover__fallback {
  width: 100%;
  height: 100%;
  display: block;
}

.company-video-cover__fallback {
  background:
    linear-gradient(135deg, rgba(var(--brand-rgb), 0.32), rgba(15, 23, 42, 0.96)),
    #0f172a;
}

.company-video-cover__shade {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.08), rgba(15, 23, 42, 0.32));
}

.company-video-cover__play {
  position: absolute;
  left: 28rpx;
  bottom: 24rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 23, 42, 0.58);
  backdrop-filter: blur(10rpx);
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.24);
}

.profile-story {
  position: relative;
  display: grid;
  gap: 22rpx;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.intro-block {
  position: relative;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.company-module .intro-block--heading {
  padding: 34rpx 30rpx 30rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background:
    radial-gradient(circle at 88% 12%, rgba(255, 255, 255, 0.24), transparent 180rpx),
    linear-gradient(135deg, var(--brand-deep), var(--brand));
  overflow: hidden;
  box-shadow: 0 18rpx 42rpx rgba(22, 119, 255, 0.22);
  box-sizing: border-box;
}

.company-module .intro-block--heading::after {
  content: "";
  position: absolute;
  right: -68rpx;
  bottom: -86rpx;
  width: 220rpx;
  height: 220rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 50%;
}

.company-module .intro-kicker {
  position: relative;
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: rgba(255, 255, 255, 0.86);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.company-module .intro-heading {
  position: relative;
  margin-top: 18rpx;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.24;
  max-width: 100%;
  overflow-wrap: break-word;
}

.company-module .intro-text {
  width: 100%;
  max-width: 100%;
  padding: 28rpx 30rpx;
  border-radius: 24rpx;
  color: var(--text-primary);
  font-size: 29rpx;
  line-height: 1.82;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 249, 252, 0.96));
  box-shadow: inset 0 0 0 1rpx rgba(16, 24, 40, 0.05);
  box-sizing: border-box;
  overflow-wrap: break-word;
}

.company-module .intro-text--clamp {
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 5;
  -webkit-box-orient: vertical;
}

.company-module .intro-text--quote {
  padding: 30rpx 30rpx 30rpx 36rpx;
  border-radius: 24rpx;
  border-left: 8rpx solid var(--brand);
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.68;
  background: var(--brand-tint);
}

.company-module .intro-list {
  display: grid;
  gap: 14rpx;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.company-module .intro-list__item {
  display: flex;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  color: var(--text-primary);
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(16, 24, 40, 0.06);
  width: 100%;
  max-width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.company-module .intro-list__index {
  flex: none;
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: var(--brand);
  font-size: 22rpx;
  font-weight: 700;
}

.company-module .intro-list__text {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  line-height: 1.62;
  overflow-wrap: break-word;
}

.company-module .intro-image-card,
.company-module .intro-video-card {
  width: 100%;
  max-width: 100%;
  border-radius: 28rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(16, 24, 40, 0.09);
  box-sizing: border-box;
}

.company-module .intro-image-card__image {
  width: 100%;
  height: 380rpx;
  display: block;
  background: #f2f4f7;
}

.company-module .intro-image-card__caption,
.company-module .gallery-card__caption,
.company-module .intro-video-card__meta {
  padding: 18rpx 22rpx 22rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.45;
  box-sizing: border-box;
  overflow-wrap: break-word;
}

.company-module .intro-gallery .module-scroll__track {
  padding-bottom: 6rpx;
}

.company-module .gallery-card {
  width: 560rpx;
  flex: none;
  border-radius: 24rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(16, 24, 40, 0.08);
  white-space: normal;
}

.company-module .gallery-card .gallery-image {
  border-radius: 0;
}

.intro-fold {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  margin-top: -18rpx;
  padding-top: 30rpx;
  overflow: visible;
}

.intro-fold--collapsed::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: -74rpx;
  height: 108rpx;
  pointer-events: none;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0), var(--bg-surface) 76%);
}

.intro-fold--collapsed::after {
  content: "";
  position: absolute;
  left: 36rpx;
  right: 36rpx;
  top: 28rpx;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(var(--brand-rgb), 0), rgba(var(--brand-rgb), 0.18), rgba(var(--brand-rgb), 0));
}

.intro-fold__button {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 48rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: var(--brand);
  background: var(--bg-surface);
  box-shadow: 0 0 0 10rpx var(--bg-surface);
}

.intro-fold__button:active {
  transform: translateY(2rpx);
}

.intro-fold__button text {
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1;
}

.intro-fold__arrow {
  color: rgba(var(--brand-rgb), 0.72);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.intro-fold--expanded {
  min-height: 60rpx;
  margin-top: 0;
  padding-top: 12rpx;
}

.intro-fold--expanded .intro-fold__button {
  color: var(--text-secondary);
  box-shadow: none;
}
