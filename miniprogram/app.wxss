/* ---------- 表单 ---------- */
.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
  padding: 16rpx 0;
}

.field-row + .field-row { border-top: 1rpx solid var(--divider); }
.field-row__label { display: flex; align-items: center; gap: 8rpx; color: var(--text-secondary); font-size: 28rpx; }
.field-row__value { flex: 1; margin-left: 24rpx; text-align: right; color: var(--text-primary); font-size: 28rpx; }
.field-row__value[disabled] { color: var(--text-tertiary); }

/* ---------- 名片卡（首页 / 样式预览复用） ---------- */
.biz-card {
  position: relative;
  padding: 40rpx 40rpx 32rpx 46rpx;
  border-radius: var(--r-card);
  background: var(--bg-surface);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.biz-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 12rpx;
  background: var(--brand);
}

.biz-card__head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.biz-card__logo { width: 40rpx; height: 40rpx; border-radius: 8rpx; }
.biz-card__company { font-size: 24rpx; color: var(--text-secondary); }

.biz-card__body { display: flex; justify-content: space-between; margin-top: 20rpx; }
.biz-card__name { font-size: 44rpx; font-weight: 700; line-height: 1.2; }
.biz-card__role { margin-top: 8rpx; font-size: 28rpx; color: var(--text-secondary); }

.biz-card__avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: var(--brand-tint);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--brand);
  font-size: 40rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.biz-card__contact { margin-top: 24rpx; font-size: 24rpx; color: var(--text-secondary); line-height: 1.7; }

.biz-card__status {
  position: absolute;
  right: 32rpx;
  bottom: 28rpx;
}

/* ---------- 骨架屏 ---------- */
.skeleton {
  background: linear-gradient(90deg, #edeff2 25%, #f0f2f5 37%, #edeff2 63%);
  background-size: 400% 100%;
  animation: shimmer 1.4s ease infinite;
  border-radius: 12rpx;
}

@keyframes shimmer {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}
