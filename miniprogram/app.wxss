/* ============================================================
   智云名片 · 全局设计系统（Design Tokens + 通用类 + 图标）
   画布基准 375px，小程序 1px ≈ 2rpx（满宽 750rpx）
   ============================================================ */

page {
  /* 品牌（可换肤，默认智云蓝） */
  --brand: #2b6cff;
  --brand-deep: #1e56d6;
  --brand-tint: #eaf1ff;
  --brand-soft: #a9c4ff;

  /* 中性 / 背景 */
  --text-primary: #1a1d1f;
  --text-secondary: #6b7280;
  --text-tertiary: #9aa1ac;
  --bg-page: #f4f6f8;
  --bg-surface: #ffffff;
  --divider: #edeff2;

  /* 功能语义 */
  --success: #17b26a;
  --warning: #f79009;
  --danger: #f04438;
  --success-tint: #e7f7ef;
  --warning-tint: #fef3e5;

  /* 圆角 */
  --r-chip: 12rpx;
  --r-btn: 20rpx;
  --r-card: 24rpx;
  --r-sheet: 32rpx;

  /* 阴影 */
  --shadow-card: 0 4rpx 16rpx rgba(16, 24, 40, 0.06);
  --shadow-btn: 0 8rpx 24rpx rgba(43, 108, 255, 0.28);

  background: var(--bg-page);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

/* ---------- 布局 ---------- */
.page {
  min-height: 100vh;
  padding: 24rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.page--flush {
  padding: 0 0 calc(48rpx + env(safe-area-inset-bottom));
}

.card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: var(--r-card);
  background: var(--bg-surface);
  box-shadow: var(--shadow-card);
}

.card__title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.card__more { font-size: 26rpx; color: var(--text-secondary); }

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ---------- 文本 ---------- */
.t-primary { color: var(--text-primary); }
.t-secondary { color: var(--text-secondary); }
.t-tertiary { color: var(--text-tertiary); }
.t-brand { color: var(--brand); }
.f12 { font-size: 24rpx; }
.f14 { font-size: 28rpx; }
.f16 { font-size: 32rpx; }
.f18 { font-size: 36rpx; }
.bold { font-weight: 700; }
.medium { font-weight: 500; }

/* ---------- 按钮 ---------- */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: var(--r-btn);
  font-size: 32rpx;
  font-weight: 500;
  line-height: 1;
  box-sizing: border-box;
}

.btn::after { border: none; }
.btn--primary { background: var(--brand); color: #fff; box-shadow: var(--shadow-btn); }
.btn--primary-plain { background: var(--brand-tint); color: var(--brand); }
.btn--ghost { background: var(--bg-surface); color: var(--brand); border: 3rpx solid var(--brand); }
.btn--sm { height: 64rpx; padding: 0 28rpx; font-size: 26rpx; border-radius: 16rpx; }
.btn--block { width: 100%; }

/* ---------- 徽标 / 芯片 ---------- */
.badge {
  display: inline-flex;
  align-items: center;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: var(--r-chip);
  font-size: 20rpx;
  line-height: 1;
}

.badge--success { color: var(--success); background: var(--success-tint); }
.badge--warning { color: var(--warning); background: var(--warning-tint); }
.badge--muted { color: var(--text-tertiary); background: var(--divider); }

.chip {
  display: inline-flex;
  align-items: center;
  height: 48rpx;
  padding: 0 22rpx;
  margin: 0 12rpx 12rpx 0;
  border-radius: var(--r-chip);
  font-size: 24rpx;
  color: var(--brand);
  background: var(--brand-tint);
}

/* ---------- 分隔线 / 头像 ---------- */
.divider { height: 1rpx; background: var(--divider); }
.avatar { border-radius: 50%; background: var(--brand-tint); overflow: hidden; }

/* ---------- 图标（线性 SVG，线宽 1.5px） ---------- */
.icon {
  display: inline-block;
  width: 48rpx;
  height: 48rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
}

.icon--sm { width: 40rpx; height: 40rpx; }
.icon--lg { width: 56rpx; height: 56rpx; }

